---
interface Capability {
  heading: string;
  text: string;
}

interface Props {
  capabilities: Capability[];
}

const { capabilities } = Astro.props;
const techCapabilities = capabilities.slice(0, 3);
const aiCapabilities = capabilities.slice(3);
---

<section class="capabilities-section container py-5 my-sm-2 my-md-4 my-lg-5">
  <div class="capabilities-inner">
    <h2 class="capabilities-main-title text-center mx-auto">
      <span>Technical Capabilities</span> & Enabling Platform
    </h2>

    <div class="capabilities-grid mb-5 pb-3">
      {
        techCapabilities.map((item, idx) => (
          <div class="capability-card">
            <div class="capability-card-glow"></div>
            <div class="capability-header">
              <span class="capability-number">0{idx + 1}</span>
            </div>
            <h3 class="capability-title">{item.heading}</h3>
            <p class="capability-text">{item.text}</p>
          </div>
        ))
      }
    </div>

    {aiCapabilities.length > 0 && (
      <>
        <h2 class="capabilities-main-title text-center mx-auto mt-5 pt-4">
          <span>Responsible AI</span> and Governance
        </h2>

        <div class="capabilities-grid">
          {
            aiCapabilities.map((item, idx) => (
              <div class="capability-card">
                <div class="capability-card-glow"></div>
                <div class="capability-header">
                  <span class="capability-number">0{idx + 4}</span>
                </div>
                <h3 class="capability-title">{item.heading}</h3>
                <p class="capability-text">{item.text}</p>
              </div>
            ))
          }
        </div>
      </>
    )}
  </div>
</section>