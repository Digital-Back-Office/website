---
import '../../styles/service.css';

interface Card {
  title: string;
  description: string;
  frontImage: string;
  frontColor: string;
  backColor: string;
  borderColor?: string;
}

interface Pill {
  key: string;
  label: string;
}

interface IndustryDetail {
  title: string;
  bullets: string[];
}

export interface Props {
  title: string;
  subtitle: string;
  cards: Card[];
  industrySectionTitle: string;
  industrySectionSubtitle: string;
  pills: Pill[];
  industries: Record<string, IndustryDetail>;
}

const {
  title,
  subtitle,
  cards,
  industrySectionTitle,
  industrySectionSubtitle,
  pills,
  industries,
} = Astro.props;

// Defensive defaults so a malformed/missing content entry doesn't crash the page during SSR
const safeCards = Array.isArray(cards) ? cards : [];
const safePills = Array.isArray(pills) ? pills : [];
const safeIndustries = industries && typeof industries === 'object' ? industries : {};


function getIconByTitle(title: string): string {
  const t = title.toLowerCase();
  if (t.includes('quality')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 11 2 2 4-4"/></svg>`;
  }
  if (t.includes('deep learning')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="2.5"/><circle cx="5" cy="12" r="2.5"/><circle cx="19" cy="12" r="2.5"/><circle cx="12" cy="19" r="2.5"/><line x1="12" y1="7.5" x2="12" y2="16.5"/><line x1="6.8" y1="13.8" x2="10.2" y2="17.2"/><line x1="17.2" y1="13.8" x2="13.8" y2="17.2"/><line x1="6.8" y1="10.2" x2="10.2" y2="6.8"/><line x1="17.2" y1="10.2" x2="13.8" y2="6.8"/></svg>`;
  }
  if (t.includes('predictive modeling') || t.includes('predictive analysis')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="m3 16 4-4 4 4 6-6 4 4"/><circle cx="3" cy="16" r="1"/><circle cx="7" cy="12" r="1"/><circle cx="11" cy="16" r="1"/><circle cx="17" cy="10" r="1"/><line x1="17" y1="10" x2="21" y2="6" stroke-dasharray="2 2"/><circle cx="21" cy="6" r="1"/></svg>`;
  }
  if (t.includes('timeseries') || t.includes('time series') || t.includes('time-series')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10" stroke-dasharray="2 2"/></svg>`;
  }
  if (t.includes('visualization') || t.includes('dashboard') || t.includes('analytics dashboards') || t.includes('business intelligence') || t.includes('bi')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="15" y1="12" x2="15" y2="21"/></svg>`;
  }
  if (t.includes('classification') || t.includes('nlp') || t.includes('vision') || t.includes('natural language')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/><path d="M3 3h2v2H3zM21 3h-2v2h2zM3 21h2v-2H3zM21 21h-2v-2h2z"/></svg>`;
  }
  if (t.includes('pipeline') || t.includes('etl')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h16M4 18h16"/><polyline points="16 3 19 6 16 9"/><polyline points="8 9 11 12 8 15"/><polyline points="16 15 19 18 16 21"/></svg>`;
  }
  if (t.includes('ops')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 12c-2-2.67-4-4-6-4a4 4 0 1 0 0 8c2 0 4-1.33 6-4Zm0 0c2 2.67 4 4 6 4a4 4 0 1 0 0-8c-2 0-4 1.33-6 4Z"/></svg>`;
  }
  if (t.includes('mesh')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="6" cy="6" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="6" cy="18" r="2"/><circle cx="18" cy="18" r="2"/><line x1="8.5" y1="8.5" x2="10" y2="10"/><line x1="15.5" y1="8.5" x2="14" y2="10"/><line x1="8.5" y1="15.5" x2="10" y2="14"/><line x1="15.5" y1="15.5" x2="14" y2="14"/></svg>`;
  }
  if (t.includes('architecture')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`;
  }
  if (t.includes('cloud')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19A5.5 5.5 0 0 0 22 14.5a6 6 0 0 0-6-6h-1A8 8 0 1 0 3 15.5A5.5 5.5 0 0 0 8.5 19H17.5Z"/><polyline points="12 15 12 11 10 13"/></svg>`;
  }
  if (t.includes('governance')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><rect x="9" y="10" width="6" height="5" rx="1"/><circle cx="12" cy="7" r="1"/></svg>`;
  }
  if (t.includes('roadmap') || t.includes('plan')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4v16h16"/><path d="M8 12h8"/><circle cx="8" cy="12" r="2"/><circle cx="16" cy="12" r="2"/><path d="m13 8 3 4-3 4"/></svg>`;
  }
  if (t.includes('readiness') || t.includes('assessment')) {
    return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.886H3.896l5.017 3.645L7 18.417l5-3.64 5 3.64-1.913-5.886 5.017-3.645h-6.192L12 3Z"/></svg>`;
  }
  return `<svg class="bento-svg-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>`;
}

function getGraphicByTitle(title: string): string {
  const t = title.toLowerCase();
  
  if (t.includes('quality')) {
    return `<svg width="100%" height="100%" viewBox="0 0 240 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="bento-graphic-svg">
      <defs>
        <linearGradient id="grad-dq" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#30baba" stop-opacity="0.8"/>
          <stop offset="100%" stop-color="#248787" stop-opacity="0.2"/>
        </linearGradient>
      </defs>
      <path d="M10 20h220M10 50h220M10 80h220M10 110h220M10 140h220" stroke="rgba(48,186,186,0.04)" stroke-width="1"/>
      <path d="M40 10v140M90 10v140M140 10v140M190 10v140" stroke="rgba(48,186,186,0.04)" stroke-width="1"/>
      <path d="M20 80h70m60 0h70" stroke="rgba(15,23,42,0.1)" stroke-width="2" stroke-dasharray="4 4"/>
      <circle cx="40" cy="80" r="6" fill="#64748b" opacity="0.6"/>
      <circle cx="65" cy="80" r="6" fill="#64748b" opacity="0.8"/>
      <rect x="90" y="50" width="60" height="60" rx="12" fill="url(#grad-dq)" stroke="#30baba" stroke-width="2"/>
      <circle cx="120" cy="80" r="14" fill="rgba(255,255,255,0.15)" stroke="#ffffff" stroke-width="1.5"/>
      <path d="m115 80 3 3 7-7" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="175" cy="80" r="6" fill="#30baba"/>
      <circle cx="205" cy="80" r="6" fill="#30baba"/>
      <rect x="100" y="125" width="40" height="12" rx="4" fill="rgba(48,186,186,0.1)" stroke="#30baba" stroke-width="1"/>
      <text x="120" y="133" fill="#248787" font-size="7" font-family="monospace" text-anchor="middle" font-weight="bold">ACTIVE</text>
    </svg>`;
  }
  
  if (t.includes('timeseries') || t.includes('time series') || t.includes('time-series')) {
    return `<svg width="100%" height="100%" viewBox="0 0 240 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="bento-graphic-svg">
      <defs>
        <linearGradient id="grad-ts" x1="0%" y1="100%" x2="0%" y2="0%">
          <stop offset="0%" stop-color="#30baba" stop-opacity="0"/>
          <stop offset="100%" stop-color="#30baba" stop-opacity="0.15"/>
        </linearGradient>
      </defs>
      <path d="M20 20h200M20 50h200M20 80h200M20 110h200M20 140h200" stroke="rgba(15,23,42,0.03)" stroke-width="1"/>
      <path d="M20 120 l25-35 30 15 35-45 40 25 35-50 35 15 V140 H20 Z" fill="url(#grad-ts)"/>
      <path d="M20 120 l25-35 30 15 35-45 40 25" stroke="#64748b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <line x1="150" y1="20" x2="150" y2="140" stroke="#30baba" stroke-width="1.5" stroke-dasharray="3 3"/>
      <path d="M150 80 l35-50 35 15" stroke="#30baba" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="1 1"/>
      <circle cx="150" cy="80" r="4" fill="#30baba" stroke="#ffffff" stroke-width="1.5"/>
      <circle cx="185" cy="30" r="4" fill="#30baba" stroke="#ffffff" stroke-width="1.5"/>
      <circle cx="220" cy="45" r="4" fill="#30baba" stroke="#ffffff" stroke-width="1.5"/>
      <rect x="158" y="85" width="55" height="15" rx="4" fill="var(--bg-surface)" stroke="var(--border-subtle)" stroke-width="1"/>
      <text x="185" y="95" fill="var(--text-secondary)" font-size="7" font-family="sans-serif" text-anchor="middle">FORECAST</text>
    </svg>`;
  }
  
  if (t.includes('visualization') || t.includes('dashboard') || t.includes('analytics dashboards')) {
    return `<svg width="100%" height="100%" viewBox="0 0 240 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="bento-graphic-svg">
      <rect x="15" y="15" width="210" height="130" rx="8" fill="var(--bg-contrast)" stroke="var(--border-subtle)" stroke-width="1.5"/>
      <rect x="25" y="25" width="40" height="8" rx="2" fill="rgba(15, 23, 42, 0.15)" opacity="0.3"/>
      <circle cx="205" cy="29" r="3" fill="#ef4444" opacity="0.6"/>
      <circle cx="195" cy="29" r="3" fill="#eab308" opacity="0.6"/>
      <circle cx="185" cy="29" r="3" fill="#22c55e" opacity="0.6"/>
      <rect x="25" y="45" width="90" height="85" rx="6" fill="var(--bg-surface)" stroke="var(--border-subtle)" stroke-width="1"/>
      <rect x="35" y="95" width="8" height="25" rx="2" fill="#30baba" opacity="0.7"/>
      <rect x="50" y="75" width="8" height="45" rx="2" fill="#30baba"/>
      <rect x="65" y="85" width="8" height="35" rx="2" fill="#30baba" opacity="0.8"/>
      <rect x="80" y="60" width="8" height="60" rx="2" fill="#248787"/>
      <rect x="95" y="90" width="8" height="30" rx="2" fill="#30baba" opacity="0.5"/>
      <rect x="125" y="45" width="90" height="40" rx="6" fill="var(--bg-surface)" stroke="var(--border-subtle)" stroke-width="1"/>
      <circle cx="150" cy="65" r="12" fill="none" stroke="var(--border-subtle)" stroke-width="2.5"/>
      <path d="M150 53 a12 12 0 0 1 12 12" fill="none" stroke="#30baba" stroke-width="3" stroke-linecap="round"/>
      <text x="178" y="68" fill="var(--text-primary)" font-size="10" font-weight="bold" font-family="sans-serif">84%</text>
      <rect x="125" y="90" width="90" height="40" rx="6" fill="var(--bg-surface)" stroke="var(--border-subtle)" stroke-width="1"/>
      <text x="135" y="105" fill="var(--text-muted)" font-size="7" font-family="sans-serif">TOTAL CONVERSION</text>
      <text x="135" y="122" fill="#248787" font-size="14" font-weight="bold" font-family="sans-serif">$24.8K</text>
    </svg>`;
  }
  
  if (t.includes('ops')) {
    return `<svg width="100%" height="100%" viewBox="0 0 240 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="bento-graphic-svg">
      <path d="M70 80c25 33 45 33 70 0s45-33 70 0-45 33-70 0-45-33-70 0Z" stroke="var(--border-strong)" stroke-width="3" fill="none"/>
      <path d="M70 80c25 33 45 33 70 0s45-33 70 0-45 33-70 0-45-33-70 0Z" stroke="#30baba" stroke-width="1.5" stroke-dasharray="6 6" fill="none"/>
      <circle cx="45" cy="80" r="5" fill="#30baba" stroke="#ffffff" stroke-width="1"/>
      <circle cx="105" cy="60" r="5" fill="#248787" stroke="#ffffff" stroke-width="1"/>
      <circle cx="135" cy="100" r="5" fill="#248787" stroke="#ffffff" stroke-width="1"/>
      <circle cx="195" cy="80" r="5" fill="#30baba" stroke="#ffffff" stroke-width="1"/>
      <rect x="25" y="105" width="45" height="14" rx="4" fill="var(--bg-surface)" stroke="var(--border-subtle)" stroke-width="1"/>
      <text x="47.5" y="114" fill="var(--text-secondary)" font-size="6.5" font-family="sans-serif" text-anchor="middle">DEVOPS</text>
      <rect x="170" y="40" width="45" height="14" rx="4" fill="var(--bg-surface)" stroke="var(--border-subtle)" stroke-width="1"/>
      <text x="192.5" y="49" fill="var(--text-secondary)" font-size="6.5" font-family="sans-serif" text-anchor="middle">MLOPS</text>
    </svg>`;
  }
  
  if (t.includes('governance')) {
    return `<svg width="100%" height="100%" viewBox="0 0 240 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="bento-graphic-svg">
      <defs>
        <linearGradient id="grad-gov" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#30baba" stop-opacity="0.8"/>
          <stop offset="100%" stop-color="#248787" stop-opacity="0.2"/>
        </linearGradient>
      </defs>
      <rect x="30" y="30" width="50" height="25" rx="4" fill="var(--bg-surface)" stroke="var(--border-subtle)" stroke-width="1.5"/>
      <line x1="30" y1="38" x2="80" y2="38" stroke="var(--border-subtle)"/>
      <line x1="30" y1="46" x2="80" y2="46" stroke="var(--border-subtle)"/>
      <circle cx="40" cy="34" r="1.5" fill="#30baba"/>
      <circle cx="40" cy="42" r="1.5" fill="#30baba"/>
      <circle cx="40" cy="50" r="1.5" fill="#30baba"/>
      
      <rect x="30" y="105" width="50" height="25" rx="4" fill="var(--bg-surface)" stroke="var(--border-subtle)" stroke-width="1.5"/>
      <line x1="30" y1="113" x2="80" y2="113" stroke="var(--border-subtle)"/>
      <line x1="30" y1="121" x2="80" y2="121" stroke="var(--border-subtle)"/>
      <circle cx="40" cy="109" r="1.5" fill="#30baba"/>
      <circle cx="40" cy="117" r="1.5" fill="#30baba"/>
      <circle cx="40" cy="125" r="1.5" fill="#30baba"/>
      
      <path d="M80 42 L130 80 M80 117 L130 80" stroke="rgba(15,23,42,0.15)" stroke-width="1.5" stroke-dasharray="3 3"/>
      
      <rect x="130" y="50" width="60" height="60" rx="12" fill="url(#grad-gov)" stroke="#30baba" stroke-width="2"/>
      <path d="M160 62 c-4 0-8-3-8-3v9c0 5 8 9 8 9s8-4 8-9v-9s-4 3-8 3Z" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="m156 71 3 3 5-5" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`;
  }
  
  if (t.includes('roadmap') || t.includes('plan')) {
    return `<svg width="100%" height="100%" viewBox="0 0 240 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="bento-graphic-svg">
      <path d="M30 130 C60 130 80 40 120 40 C160 40 180 120 210 120" stroke="rgba(15,23,42,0.15)" stroke-width="4" stroke-linecap="round" fill="none"/>
      <path d="M30 130 C60 130 80 40 120 40 C160 40 180 120 210 120" stroke="#30baba" stroke-width="2" stroke-dasharray="4 4" stroke-linecap="round" fill="none"/>
      
      <circle cx="50" cy="115" r="10" fill="var(--bg-surface)" stroke="#30baba" stroke-width="2"/>
      <text x="50" y="118" fill="#248787" font-size="8" font-family="monospace" text-anchor="middle" font-weight="bold">Q1</text>
      
      <circle cx="120" cy="40" r="10" fill="var(--bg-surface)" stroke="#30baba" stroke-width="2"/>
      <text x="120" y="43" fill="#248787" font-size="8" font-family="monospace" text-anchor="middle" font-weight="bold">Q2</text>
      
      <circle cx="190" cy="100" r="10" fill="var(--bg-surface)" stroke="#30baba" stroke-width="2"/>
      <text x="190" y="103" fill="#248787" font-size="8" font-family="monospace" text-anchor="middle" font-weight="bold">Q3</text>
    </svg>`;
  }
  
  return `<svg width="100%" height="100%" viewBox="0 0 240 160" fill="none" xmlns="http://www.w3.org/2000/svg" class="bento-graphic-svg">
    <circle cx="120" cy="80" r="50" stroke="rgba(48,186,186,0.15)" stroke-width="1.5" stroke-dasharray="4 4"/>
    <circle cx="120" cy="80" r="30" stroke="rgba(48,186,186,0.25)" stroke-width="2"/>
    <circle cx="120" cy="80" r="10" fill="#30baba"/>
    <path d="M120 20v120M60 80h120" stroke="rgba(15,23,42,0.03)" stroke-width="1"/>
  </svg>`;
}

---

<section class="service-showcase-section">
  <div class="container">
    <h2 class="service-showcase-main-title">{title}</h2>
    <p class="service-showcase-main-subtitle">{subtitle}</p>
 
    <div class="service-showcase-grid">
      {safeCards.map((card, index) => {
        const isWide = index === 0 || index === 3 || index === 4;
        return (
          <div class={`service-showcase-card ${isWide ? 'bento-wide' : ''}`}>
            <div class="service-showcase-glow"></div>
            {isWide ? (
              <>
                <div class="bento-content">
                  <div class="service-showcase-icon-wrapper">
                    <Fragment set:html={getIconByTitle(card.title)} />
                  </div>
                  <h3 class="service-showcase-card-title">{card.title}</h3>
                  <p class="service-showcase-card-text">{card.description}</p>
                </div>
                <div class="bento-graphic-col">
                  <Fragment set:html={getGraphicByTitle(card.title)} />
                </div>
              </>
            ) : (
              <div class="service-showcase-body">
                <div class="service-showcase-icon-wrapper">
                  <Fragment set:html={getIconByTitle(card.title)} />
                </div>
                <h3 class="service-showcase-card-title">{card.title}</h3>
                <p class="service-showcase-card-text">{card.description}</p>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>

<section style="padding: 80px 0;" >
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    <h2 style="text-align: center; font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem;">{industrySectionTitle}</h2>
    <p style="text-align: center; margin-bottom: 3rem;">{industrySectionSubtitle}</p>

    <div class="industry-pills-container">
      {safePills.map((pill) => (
        <button
          class={`industry-pill ${pill === pills[0] ? 'active-pill' : ''}`}
          data-industry={pill.key}
        >
          {pill.label}
        </button>
      ))}
    </div>

    <div style="padding: 2.5rem; background-color: var(--bg-contrast); border-radius: 20px; box-shadow: var(--shadow-lg)">
      {Object.entries(safeIndustries).map(([key, industry], index) => (
        <div
          id={`industry-${key}`}
          class="industry-content"
          style={`display: ${index === 0 ? 'block' : 'none'};`}
        >
          <h3 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1.25rem;">{industry.title}</h3>
          <ul style="line-height: 1.8; color: var(--text-secondary); margin-bottom: 0; padding-left: 1.5rem;">
            {industry.bullets.map((bullet) => (
              <li style="margin-bottom: 0.75rem;">{bullet}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const industryPills = document.querySelectorAll('.industry-pill');
    const industryContents = document.querySelectorAll('.industry-content');

    industryPills.forEach((pill) => {
      pill.addEventListener('click', function (event) {
        const target = event.currentTarget as HTMLElement;
        const industry = target.getAttribute('data-industry');

        industryPills.forEach((p) => p.classList.remove('active-pill'));
        target.classList.add('active-pill');

        industryContents.forEach((content) => {
          (content as HTMLElement).style.display = 'none';
        });

        const selectedContent = document.getElementById('industry-' + industry);
        if (selectedContent) {
          selectedContent.style.display = 'block';
        }
      });
    });
  });
</script>
