---
interface Props {
  id?: string;
  section: {
    badge: string;
    heading: string;
    text: string;
    image_placeholder: string;
    cards: Array<{
      title: string;
      description: string;
    }>;
  };
  imagePosition?: "left" | "right";
}

const { id, section, imagePosition = "right" } = Astro.props;
const isImageRight = imagePosition === "right";
import Button from "../ui/Button.astro";
---

<style>
  .service-section {
    padding: 1.5rem;
    background-color: transparent;
    margin-bottom: 1.5rem;
    height: 100%;
  }

  .service-badge {
    display: inline-block;
    background-color: rgba(82, 206, 199, 0.08);
    border: 1px solid rgba(82, 206, 199, 0.2);
    border-radius: var(--radius-sm);
    padding: 0.35rem 1rem;
    margin-bottom: 1.5rem;
    color: var(--brand-teal-alt);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .service-heading {
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .service-lead-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 2.25rem;
  }

  .service-image-container {
    border-radius: var(--radius-xl);
    /* border: 1px solid rgba(0, 0, 0, 0.15); */
    width: 100%;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    /* padding: .5rem; */
    position: relative;
    overflow: hidden;
    /* box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2); */
  }

  .service-image-glow {
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      circle,
      rgba(82, 206, 199, 0.08) 0%,
      transparent 70%
    );
    opacity: 0.5;
    pointer-events: none;
  }

  .service-section-image {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.2));
  }

  .service-info-card {
    background: rgba(255, 255, 255, 0.015);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    height: 100%;
    transition:
      border-color var(--motion-base),
      background-color var(--motion-base);
  }

  .service-info-card:hover {
    border-color: rgba(82, 206, 199, 0.25);
    background: rgba(255, 255, 255, 0.025);
  }

  .service-info-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .service-info-card-text {
    font-size: 0.7rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .order-1 {
      order: 1 !important;
    }
    .order-2 {
      order: 2 !important;
    }
  }
</style>

<section id={id} class="service-section">
  <div class="align-items-center h-100 d-flex flex-column">
    <div class="mb-4 mb-lg-0 w-100">
      <div class="service-badge">
        <span>{section.badge}</span>
      </div>
      <h2 class="service-heading">
        {section.heading}
      </h2>
      <p class="service-lead-text">
        {section.text}
      </p>
    </div>
    <div class="w-100 mt-auto">
      <div class="service-image-container mb-4">
        <img
          src={section.image_placeholder}
          alt={section.heading}
          class="service-section-image"
        />
      </div>

      <div class="row row-cols-1 row-cols-xl-3 g-3 mb-4">
        {
          section.cards.map((card) => (
            <div class="col">
              <div class="service-info-card">
                <h3 class="service-info-card-title">{card.title}</h3>
                <p class="service-info-card-text">{card.description}</p>
              </div>
            </div>
          ))
        }
      </div>
      <Button href="/contact-us" variant="outline">
        <span>Get started</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </Button>
    </div>
  </div>
</section>
