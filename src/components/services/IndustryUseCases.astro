---
interface UseCase {
  title: string;
  description: string;
}

interface Industry {
  industry: string;
  use_cases: UseCase[];
}

interface Props {
  heading: string;
  subtitle: string;
  cases: Industry[];
}

const { heading, subtitle, cases } = Astro.props;
---

<style>
  .use-cases-section {
    padding: 6rem 0;
    margin-bottom: 3rem;
  }

  .use-cases-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 1.5rem;
  }

  .use-cases-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.75);
    max-width: 800px;
    margin: 0 auto;
  }

  .use-case-card {
    background: rgba(255, 255, 255, 0.02);
    border-radius: var(--radius-xl);
    padding: 3rem;
    height: 100%;
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color var(--motion-base), background-color var(--motion-base);
  }

  .use-case-card:hover {
    border-color: rgba(82, 206, 199, 0.25);
    background: rgba(255, 255, 255, 0.035);
  }

  .use-case-industry-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--brand-teal-alt);
    margin-bottom: 1.5rem;
  }

  .use-cases-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-case-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .use-case-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .use-case-item:first-child {
    padding-top: 0;
  }

  .use-case-item-title {
    color: #fff;
    display: block;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .use-case-item-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  @media (max-width: 768px) {
    .use-case-card {
      padding: 2rem;
    }
  }
</style>

<section class="use-cases-section">
  <div class="container">
    <div class="text-center mb-5">
      <h2 class="use-cases-title">
        {heading}
      </h2>
      <p class="use-cases-subtitle">
        {subtitle}
      </p>
    </div>

    <div class="row g-4">
      {cases.map((industryCase) => (
        <div class="col-12">
          <div class="use-case-card">
            <h3 class="use-case-industry-title">
              {industryCase.industry}
            </h3>
            <ul class="use-cases-list">
              {industryCase.use_cases.map((useCase) => (
                <li class="use-case-item">
                  <strong class="use-case-item-title">{useCase.title}</strong>
                  <span class="use-case-item-desc" set:html={useCase.description}></span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
