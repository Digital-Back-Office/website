---
/* INDUSTRIALS: 3D Isometric Platforms (IoT Gears, Edge Turbine Core, & Grid Transmission Tower) */
---
<svg class="architecture-svg" viewBox="0 0 950 450" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Background Glow -->
    <radialGradient id="ind-bg-glow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="var(--brand-yellow)" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="var(--brand-yellow)" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="ind-plat-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="var(--brand-cyan)"/>
      <stop offset="100%" stop-color="var(--brand-yellow)"/>
    </linearGradient>
  </defs>

  <rect width="100%" height="100%" fill="none" />
  <circle cx="475" cy="225" r="350" fill="url(#ind-bg-glow)" pointer-events="none" />

  <!-- Isometric Matrix background -->
  <g stroke="rgba(255, 255, 255, 0.02)" stroke-width="1">
    <path d="M 50 150 L 900 370 M 50 250 L 900 470 M 50 50 L 900 270" />
    <path d="M 900 150 L 50 370 M 900 250 L 50 470 M 900 50 L 50 270" />
  </g>

  <!-- Developer console telemetry printout (Top) -->
  <text x="475" y="40" text-anchor="middle" fill="rgba(82, 206, 199, 0.6)" font-family="monospace" font-size="10" font-weight="700" letter-spacing="1">
    SCADA EDGE TELEMETRY // EDGE SAMPLING: 24 kHz // OVERRIDE STATE: NOMINAL // HEALTH: 100%
  </text>

  <!-- 1. LEFT PLATFORM: INGESTION (cx=220, cy=280) -->
  <g class="node-group">
    <!-- Platform Base Shadow -->
    <polygon points="140,295 220,335 220,350 140,310" fill="#04070d" />
    <polygon points="220,335 300,295 300,310 220,350" fill="#050912" />
    <!-- Platform Base Left/Right Faces -->
    <polygon points="140,280 220,320 220,335 140,295" fill="#080e1a" stroke="rgba(255,255,255,0.04)" />
    <polygon points="220,320 300,280 300,295 220,335" fill="#0b1326" stroke="rgba(255,255,255,0.04)" />
    <!-- Platform Top Face -->
    <polygon points="140,280 220,240 300,280 220,320" fill="#090d16" stroke="var(--brand-cyan)" stroke-width="1.5" />

    <!-- 3D Isometric Gears -->
    <g transform="translate(180, 230)" stroke="var(--brand-cyan)" stroke-width="1.8" fill="none">
      <!-- Gear A (Left) -->
      <ellipse cx="20" cy="20" rx="15" ry="7" />
      <circle cx="20" cy="20" r="3" fill="var(--brand-cyan)" />
      <line x1="20" y1="13" x2="20" y2="7" />
      <line x1="20" y1="27" x2="20" y2="33" />

      <!-- Gear B (Right, meshed) -->
      <g transform="translate(25, 10)">
        <ellipse cx="20" cy="20" rx="12" ry="5.5" opacity="0.7" />
        <circle cx="20" cy="20" r="2.5" fill="var(--brand-cyan)" />
      </g>
    </g>

    <text x="220" y="375" text-anchor="middle" fill="var(--text-secondary)" font-size="9" font-weight="700">SCADA EDGE SENSORS</text>
  </g>

  <!-- 2. CENTRAL PLATFORM: EDGE TURBINE CORE (cx=475, cy=240, Taller block structure) -->
  <!-- Wires connecting Ingest -> Central -->
  <path d="M 270,265 Q 370,225 425,200" stroke="url(#ind-plat-grad)" stroke-width="2.5" stroke-dasharray="6 4" />
  <circle r="4" fill="var(--brand-cyan)">
    <animateMotion dur="3s" repeatCount="indefinite" path="M 270,265 Q 370,225 425,200" />
  </circle>

  <g class="node-group main-engine">
    <!-- Big base column -->
    <polygon points="375,250 475,300 475,340 375,290" fill="#050912" />
    <polygon points="475,300 575,250 575,290 475,340" fill="#080e1c" />
    <polygon points="375,250 475,200 575,250 475,300" fill="#090d19" stroke="var(--brand-yellow)" stroke-width="2" />

    <!-- Second Stacked Block -->
    <g transform="translate(0, -40)">
      <polygon points="415,230 475,260 475,290 415,260" fill="#0b1224" />
      <polygon points="475,260 535,230 535,260 475,290" fill="#0d1830" />
      <polygon points="415,230 475,200 535,230 475,260" fill="#0c1429" stroke="var(--brand-yellow)" stroke-width="1" />
    </g>

    <!-- Concentric Turbine Rings spinning in 3D space above Core -->
    <g transform="translate(0, -90)">
      <ellipse cx="475" cy="200" rx="40" ry="16" stroke="var(--brand-yellow)" stroke-width="2.5" fill="none" />
      <ellipse cx="475" cy="200" rx="25" ry="10" stroke="var(--brand-yellow)" stroke-width="1.5" stroke-dasharray="4 2" fill="none" />
      <line x1="450" y1="200" x2="500" y2="200" stroke="var(--brand-yellow)" stroke-width="1.8" />
    </g>

    <text x="475" y="325" text-anchor="middle" fill="var(--text-primary)" font-size="11" font-weight="900" letter-spacing="1">EDGE CONTROL</text>
  </g>

  <!-- 3. RIGHT PLATFORM: GRID DISPATCH (cx=730, cy=280) -->
  <!-- Wires connecting Central -> Grid -->
  <path d="M 525,215 Q 615,225 680,265" stroke="url(#ind-plat-grad)" stroke-width="2" stroke-dasharray="6 4" />
  <circle r="4.5" fill="var(--brand-yellow)">
    <animateMotion dur="3.5s" repeatCount="indefinite" path="M 525,215 Q 615,225 680,265" />
  </circle>

  <g class="node-group">
    <!-- Platform Base -->
    <polygon points="650,295 730,335 730,350 650,310" fill="#04070d" />
    <polygon points="730,335 810,295 810,310 730,350" fill="#050912" />
    <polygon points="650,280 730,320 730,335 650,295" fill="#080e1a" stroke="rgba(255,255,255,0.04)" />
    <polygon points="730,320 810,280 810,295 730,335" fill="#0b1326" stroke="rgba(255,255,255,0.04)" />
    <polygon points="650,280 730,240 810,280 730,320" fill="#090d16" stroke="var(--brand-teal-alt)" stroke-width="1.5" />

    <!-- 3D Transmission Tower vector above platform -->
    <g transform="translate(705, 160)" stroke="var(--brand-teal-alt)" stroke-width="1.5" fill="none">
      <!-- Tower frame -->
      <polygon points="25,90 10,40 40,40 25,90" />
      <line x1="25" y1="40" x2="25" y2="10" />
      <!-- Cross arms -->
      <line x1="0" y1="40" x2="50" y2="40" />
      <line x1="10" y1="20" x2="40" y2="20" />
    </g>

    <text x="730" y="375" text-anchor="middle" fill="var(--text-secondary)" font-size="9" font-weight="700">GRID TRANSMISSION</text>
  </g>

  <!-- Developer console telemetry printout (Bottom) -->
  <text x="475" y="425" text-anchor="middle" fill="rgba(82, 206, 199, 0.6)" font-family="monospace" font-size="10" font-weight="700" letter-spacing="1">
    GRID LOAD: 842MW | CO2 INDEX: MINIMAL | TURBINE EFFICIENCY: 99.8% | PLC STATUS: RUNNING
  </text>
</svg>
