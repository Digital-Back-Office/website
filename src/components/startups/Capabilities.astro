---
---

<section class="pod-services" id="capabilities">
  <div class="container">
    <div class="text-center mb-5">
      <div class="badge-container mb-3" style="display: inline-block; background-color: rgba(82, 206, 199, 0.1); border-radius: 50px; padding: 0.35rem 1.25rem; border: 1px solid rgba(82, 206, 199, 0.2);">
        <span style="font-size: 0.8rem; font-weight: 600; color: #52CEC7; text-transform: uppercase;">A Single Pod. Full Coverage.</span>
      </div>
      <h2 class="h1 text-white">Startup Pod Capabilities</h2>
      <p class="text-white opacity-70 max-width-600 mx-auto">We provide the technical expertise of a complete, cross-functional software product team.</p>
    </div>

    <div class="row g-4">
      <div class="col-lg-3 col-md-6">
        <div class="service-card">
          <div class="service-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#52CEC7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"></path>
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path>
            </svg>
          </div>
          <h3 class="h5 text-white mb-2">UX & UI Design</h3>
          <p class="text-white opacity-70 mb-0">User research, interactive Figma design prototypes, and intuitive interface layouts built for conversions.</p>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-6">
        <div class="service-card">
          <div class="service-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#52CEC7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
              <line x1="8" y1="21" x2="16" y2="21"></line>
              <line x1="12" y1="17" x2="12" y2="21"></line>
            </svg>
          </div>
          <h3 class="h5 text-white mb-2">Backend & Frontend</h3>
          <p class="text-white opacity-70 mb-0">Sleek Web/Mobile applications built on modern frameworks (React, Next.js, Node, Python) with clean architecture.</p>
        </div>
      </div>

      <div class="col-lg-3 col-md-6">
        <div class="service-card">
          <div class="service-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#52CEC7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path>
            </svg>
          </div>
          <h3 class="h5 text-white mb-2">DevOps & Cloud</h3>
          <p class="text-white opacity-70 mb-0">Automated deployment pipelines (CI/CD), secure Docker/Kubernetes container orchestration, and cloud cost management.</p>
        </div>
      </div>

      <div class="col-lg-3 col-md-6">
        <div class="service-card">
          <div class="service-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#52CEC7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
              <circle cx="12" cy="12" r="4"></circle>
            </svg>
          </div>
          <h3 class="h5 text-white mb-2">AI & ML Integration</h3>
          <p class="text-white opacity-70 mb-0">Retrieval Augmented Generation (RAG), Autonomous AI Agent workflows, and custom Large Language Model training.</p>
        </div>
      </div>
    </div>
  </div>
</section>
