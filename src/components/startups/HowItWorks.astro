---
---

<section class="how-it-works" id="how-it-works">
  <div class="container">
    <div class="text-center mb-5">
      <div class="badge-container mb-3" style="display: inline-block; background-color: rgba(82, 206, 199, 0.1); border-radius: 50px; padding: 0.35rem 1.25rem; border: 1px solid rgba(82, 206, 199, 0.2);">
        <span style="font-size: 0.8rem; font-weight: 600; color: #52CEC7; text-transform: uppercase;">Our Process</span>
      </div>
      <h2 class="h1 text-white">How We Work with Founders</h2>
      <p class="text-white opacity-70 max-width-600 mx-auto">Our structured process guarantees you launch an enterprise-grade product rapidly.</p>
    </div>

    <div class="row how-it-works-row g-4">
      <div class="col-lg-4">
        <div class="step-card">
          <div class="step-large-num">01</div>
          <div class="step-icon-container">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#52CEC7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
              <polyline points="2 17 12 22 22 17"></polyline>
              <polyline points="2 12 12 17 22 12"></polyline>
            </svg>
          </div>
          <span class="step-badge">Phase 01</span>
          <h3 class="h4 text-white mb-3">Scoping & Architecture</h3>
          <p class="text-white opacity-70 mb-0">We work directly with you to map features, choose the optimal database structure, and outline your cloud server specifications.</p>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="step-card">
          <div class="step-large-num">02</div>
          <div class="step-icon-container">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#52CEC7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
            </svg>
          </div>
          <span class="step-badge">Phase 02</span>
          <h3 class="h4 text-white mb-3">Pod Onboarding & Sprints</h3>
          <p class="text-white opacity-70 mb-0">Our designers and developers deploy instantly. We run in bi-weekly Agile sprints, providing you full visibility and daily updates.</p>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="step-card">
          <div class="step-large-num">03</div>
          <div class="step-icon-container">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#52CEC7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <span class="step-badge">Phase 03</span>
          <h3 class="h4 text-white mb-3">Production & Handover</h3>
          <p class="text-white opacity-70 mb-0">We build your automated pipeline, push the product to live servers (AWS/Azure/GCP), and provide complete technical documentation.</p>
        </div>
      </div>
    </div>
  </div>
</section>
