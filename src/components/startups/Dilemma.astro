---
---

<section class="dilemma-section" id="dilemma">
  <div class="container">
    <div class="text-center mb-5">
      <div class="badge-container mb-3" style="display: inline-block; background-color: rgba(82, 206, 199, 0.1); border-radius: 50px; padding: 0.35rem 1.25rem; border: 1px solid rgba(82, 206, 199, 0.2);">
        <span style="font-size: 0.8rem; font-weight: 600; color: #52CEC7; text-transform: uppercase;">In-House vs. Pod</span>
      </div>
      <h2 class="h1 text-white">The Startup Engineering Dilemma</h2>
      <p class="text-white opacity-70 max-width-700 mx-auto">Founders weighing this decision are almost always comparing it to hiring in-house. Here's that comparison, honestly:</p>
    </div>
    
    <div class="comparison-container">
      <div class="comparison-table-grid">
        <!-- Table Header -->
        <div class="comparison-header-row">
          <div class="comparison-cell cell-feature">
            <span class="opacity-50 fs-sm text-uppercase font-semibold tracking-wider" style="font-size: 0.8rem; letter-spacing: 1px; font-weight: 700;">Metrics</span>
          </div>
          <div class="comparison-cell cell-inhouse">
            <div class="header-subtitle text-white opacity-40">The Traditional Way</div>
            <div class="header-title text-white">Hiring In-House</div>
          </div>
          <div class="comparison-cell cell-pod">
            <div class="pod-badge">Best Choice</div>
            <div class="header-subtitle text-primary" style="color: #52CEC7 !important;">The Agile Solution</div>
            <div class="header-title text-white">Engineering Pod</div>
          </div>
        </div>

        <!-- Row 1: Monthly Cost -->
        <div class="comparison-row">
          <div class="comparison-row-content">
            <div class="comparison-cell cell-feature">
              <span>Monthly cost</span>
            </div>
            <div class="comparison-cell cell-inhouse">
              <div class="value-highlight text-coral">£25k+/month</div>
              <div class="value-sub">Salaries, taxes, benefits & agency fees.</div>
            </div>
            <div class="comparison-cell cell-pod">
              <div class="value-highlight text-cyan">From £2,500/month</div>
              <div class="value-sub">Flat monthly fee, all-inclusive, zero overhead.</div>
            </div>
          </div>
        </div>

        <!-- Row 2: Time to start -->
        <div class="comparison-row">
          <div class="comparison-row-content">
            <div class="comparison-cell cell-feature">
              <span>Time to start</span>
            </div>
            <div class="comparison-cell cell-inhouse">
              <div class="value-highlight text-coral">3–6 months hiring</div>
              <div class="value-sub">Sourcing, interviewing, vetting & notice periods.</div>
            </div>
            <div class="comparison-cell cell-pod">
              <div class="value-highlight text-cyan">Start in 48 hours</div>
              <div class="value-sub">Vetted pod ready to build and push code immediately.</div>
            </div>
          </div>
        </div>

        <!-- Row 3: What you manage -->
        <div class="comparison-row">
          <div class="comparison-row-content">
            <div class="comparison-cell cell-feature">
              <span>What you manage</span>
            </div>
            <div class="comparison-cell cell-inhouse">
              <div class="value-highlight text-coral">4+ specialists, individually</div>
              <div class="value-sub">Directly coordinating developers, designers & DevOps.</div>
            </div>
            <div class="comparison-cell cell-pod">
              <div class="value-highlight text-cyan">One team, one point of contact</div>
              <div class="value-sub">A unified pod managed by a dedicated Tech Lead.</div>
            </div>
          </div>
        </div>

        <!-- Row 4: Risk -->
        <div class="comparison-row">
          <div class="comparison-row-content">
            <div class="comparison-cell cell-feature">
              <span>Risk</span>
            </div>
            <div class="comparison-cell cell-inhouse">
              <div class="value-highlight text-coral">Recruitment risk & single points of failure</div>
              <div class="value-sub">High severance costs, bad hires & talent churn.</div>
            </div>
            <div class="comparison-cell cell-pod">
              <div class="value-highlight text-cyan">Flexible, cancel-anytime subscription</div>
              <div class="value-sub">Zero commitments, risk-free scalability.</div>
            </div>
          </div>
        </div>

        <!-- Row 5: Delivery -->
        <div class="comparison-row">
          <div class="comparison-row-content">
            <div class="comparison-cell cell-feature">
              <span>Delivery</span>
            </div>
            <div class="comparison-cell cell-inhouse">
              <div class="value-highlight text-coral">You manage the engineers</div>
              <div class="value-sub">Ensuring timelines are met, QA is run & tasks are assigned.</div>
            </div>
            <div class="comparison-cell cell-pod">
              <div class="value-highlight text-cyan">We manage delivery</div>
              <div class="value-sub">Agile execution, automated testing & continuous updates.</div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
