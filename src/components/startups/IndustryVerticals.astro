<style>
  /* Section Padding */
  .industry-verticals-section {
    padding: 7rem 0;
    position: relative;
    background: transparent;
  }

  /* Link Wrapper */
  .industry-card-link {
    text-decoration: none !important;
    display: block;
    height: 100%;
  }

  /* Rectangular Premium Card - Box design */
  .industry-vertical-card {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.015);
    backdrop-filter: blur(12px);
    border: 1.5px solid rgba(82, 206, 199, 0.12);
    border-radius: 16px;
    padding: 1.35rem 1.6rem;
    height: 100%;
    transition: all 0.35s cubic-bezier(0.165, 0.84, 0.44, 1);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  /* Hover transitions */
  .industry-vertical-card:hover {
    transform: translateY(-4px);
    border-color: rgba(82, 206, 199, 0.5);
    background: rgba(82, 206, 199, 0.025);
    box-shadow: 0 15px 35px rgba(82, 206, 199, 0.08);
  }

  /* Icon Container styling */
  .card-icon-container {
    width: 42px;
    height: 42px;
    background: rgba(82, 206, 199, 0.08);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #52CEC7;
    margin-right: 1.15rem;
    transition: all 0.3s ease;
  }

  .industry-vertical-card:hover .card-icon-container {
    background: rgba(82, 206, 199, 0.18);
    box-shadow: 0 0 12px rgba(82, 206, 199, 0.2);
  }

  /* Card Title */
  .card-title {
    font-weight: 700;
    margin: 0;
    font-size: 1.05rem;
    transition: color 0.3s ease;
    flex-grow: 1;
    padding-right: 0.5rem;
  }

  .industry-vertical-card:hover .card-title {
    color: #52CEC7 !important;
  }

  /* Link Arrow wrapper styling */
  .arrow-wrap {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .arrow-icon {
    transform: translateX(0);
    transition: transform 0.3s ease, opacity 0.3s ease;
    opacity: 0.45;
  }

  .industry-vertical-card:hover .arrow-icon {
    transform: translateX(4px);
    opacity: 1;
  }
</style>
