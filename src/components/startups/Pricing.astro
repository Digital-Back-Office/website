---
---

<section class="pricing-section" id="offer">
  <div class="container">
    <div class="text-center mb-5">
      <div class="badge-container mb-3" style="display: inline-block; background-color: rgba(82, 206, 199, 0.1); border-radius: 50px; padding: 0.35rem 1.25rem; border: 1px solid rgba(82, 206, 199, 0.2);">
        <span style="font-size: 0.8rem; font-weight: 600; color: #52CEC7; text-transform: uppercase;">Pod Pricing</span>
      </div>
      <h2 class="h1 text-white">Engineering Pod Pricing: Flat Rate From £2,500/Month</h2>
      <p class="text-white opacity-70 max-width-700 mx-auto">
        Access an elite software product team for a fraction of the cost of hiring in-house. All-inclusive flat-rate subscription, cancel or scale anytime.
      </p>
    </div>

    <div class="pricing-single-wrapper">
      <!-- Card: Core Startup Pod -->
      <div class="pricing-premium-card primary-pod single-card">
        <div class="card-content">
          <div class="card-header-top d-flex flex-wrap justify-content-between align-items-center mb-4">
            <div>
              <div class="card-badge mb-2">Pre-Seed Package</div>
              <h3 class="card-plan-title mb-0">Startup Pod</h3>
            </div>
            <div class="price-block text-md-end mt-3 mt-md-0">
              <div class="price-container mb-0">
                <span class="currency">£</span>
                <span class="amount">2,500</span>
                <span class="period">/ month</span>
              </div>
              <div class="savings-capsule mt-2 mb-0">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="me-1">
                  <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
                Save 85%+ vs. In-House
              </div>
            </div>
          </div>
          
          <p class="card-plan-desc-single mb-4">
            Digital Back Office's startup engineering pod starts at £2,500/month on a flat-rate, cancel-anytime subscription, covering UX/UI design, frontend and backend development, DevOps, and AI features, which is over 85% less than recruiting and onboarding an equivalent in-house team.
          </p>

          <hr class="card-divider" />

          <h4 class="h6 text-white text-uppercase tracking-wider mb-3" style="font-size: 0.8rem; font-weight: 700; opacity: 0.6; letter-spacing: 1px;">What is included:</h4>
          
          <ul class="card-features-list card-features-grid mb-4">
            <li>
              <div class="check-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>Complete IP Ownership & Clean Handover</span>
            </li>
            <li>
              <div class="check-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>DevOps Setup (CI/CD, secure scaling config)</span>
            </li>
            <li>
              <div class="check-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>Advanced UI frontend and backend architecture</span>
            </li>
            <li>
              <div class="check-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>AI features (Agent workflows & model endpoints)</span>
            </li>
            <li>
              <div class="check-icon">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <span>Flexible monthly terms, cancel or scale anytime</span>
            </li>
          </ul>

          <a href="#claim-offer" class="btn-pricing-cta primary-btn mt-2">
            Apply For Pod
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="ms-2">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Savings notice comparison -->
    <div class="pricing-comparison-footer text-center mt-5">
      <p class="text-white opacity-60">
        Flexible monthly rolling terms. Digital Back Office provides all-inclusive, cancel-anytime software pods.
      </p>
    </div>
  </div>
</section>
