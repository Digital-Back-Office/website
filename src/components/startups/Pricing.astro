---
---

<section class="pricing-offer" id="offer">
  <div class="container">
    <div class="pricing-box">
      <div class="row align-items-center g-5">
        <div class="col-lg-7">
          <div class="badge-container mb-3" style="display: inline-block; background-color: rgba(82, 206, 199, 0.12); border-radius: 50px; padding: 0.35rem 1.25rem; border: 1px solid rgba(82, 206, 199, 0.25);">
            <span style="font-size: 0.8rem; font-weight: 600; color: #52CEC7; text-transform: uppercase;">Pre-Seed Package</span>
          </div>
          <h2 class="display-5 fw-bold text-white mb-4">Elite Startup Pod Offer</h2>
          <p class="text-white opacity-85 mb-4">
            Access a full fractional product engineering team at a fraction of the cost. Get backend, frontend, UX design, and DevOps resources combined in a single plug-and-play monthly subscription.
          </p>
          
          <ul class="list-unstyled feature-list mb-4">
            <li><i class="ai-check-alt"></i> Complete IP Ownership & Clean Handover</li>
            <li><i class="ai-check-alt"></i> DevOps Setup (CI/CD, secure scaling config)</li>
            <li><i class="ai-check-alt"></i> Advanced UI frontend and backend architecture</li>
            <li><i class="ai-check-alt"></i> AI features (Agent workflows & model endpoints)</li>
            <li><i class="ai-check-alt"></i> Flexible monthly terms—cancel or scale anytime</li>
          </ul>
        </div>
        
        <div class="col-lg-5 text-center">
          <div class="card bg-black border-0 rounded-4 p-4 p-lg-5 mx-auto text-center" style="max-width: 400px; box-shadow: 0 30px 60px rgba(0,0,0,0.5); border: 1px solid rgba(82, 206, 199, 0.25) !important;">
            <h3 class="h5 text-white opacity-60 mb-2">Flat Rate Subscription</h3>
            <div class="display-3 fw-bold text-white mb-2">
              £2,500
            </div>
            <div class="text-primary fw-semibold mb-4">Starting per month</div>
            <hr style="border-color: rgba(255,255,255,0.1);" />
            <p class="fs-sm mb-4"><span style="color: #52CEC7 !important; font-weight: 500;">Save over 85%</span> compared to recruiting, hiring, and onboarding a traditional team.</p>
            <a href="#claim-offer" class="btn btn-lg btn-primary rounded-pill w-100" style="background: linear-gradient(135deg, #52CEC7 0%, #3BA9A3 100%); border: none; color: #000; font-weight: 600;">
              Apply For Pod
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
