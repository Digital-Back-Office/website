---
import { getEntry } from "astro:content";

const Data = await getEntry("home", "home");
const testimonials = Data.data.testimonials;
---

<style>
    .testimonials-section {
        position: relative;
        background: radial-gradient(circle at 10% 20%, rgba(82, 206, 199, 0.04) 0%, transparent 50%),
                    radial-gradient(circle at 90% 80%, rgba(238, 191, 46, 0.03) 0%, transparent 50%);
        overflow: hidden;
        padding: 5rem 0;
    }

    @media (min-width: 1024px) {
        .testimonials-section {
            min-height: 70vh;
        }
    }

    .testimonial-quotes-icon {
        color: #52CEC7;
        opacity: 0.15;
        font-size: 130px;
        line-height: 1;
        display: block;
    }

    .testimonial-title {
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -0.5px;
        line-height: 1.35;
    }

    .testimonial-text {
        font-size: 1.15rem;
        line-height: 1.8;
    }

    .btn-nav-testimonial {
        border-color: rgba(82, 206, 199, 0.3) !important;
        color: #52CEC7 !important;
        transition: all 0.3s ease !important;
    }

    .btn-nav-testimonial:hover {
        background-color: #52CEC7 !important;
        border-color: #52CEC7 !important;
        color: #000 !important;
        box-shadow: 0 0 15px rgba(82, 206, 199, 0.4);
    }
</style>

<script>
    import Swiper from "swiper/bundle";
    import "swiper/css/navigation";
    import "swiper/css/pagination";
    import "swiper/css/bundle";

    const carousels = Array.from(document.querySelectorAll(".custom-swiper"));

    carousels.forEach((value) => {
        value.classList.add('swiper');
        let options;
        const htmlValueElement = value as HTMLElement;
        if (htmlValueElement.dataset.swiperOptions != undefined)
            options = JSON.parse(htmlValueElement.dataset.swiperOptions);

        const swiper = new Swiper(htmlValueElement, options); // eslint-disable-line no-undef

        // Binded content
        if (options.bindedContent) {
            swiper.on("activeIndexChange", (e: any) => {
                const targetItem = document.querySelector(
                    e.slides[e.activeIndex].dataset.swiperBinded,
                );
                const previousItem = document.querySelector(
                    e.slides[e.previousIndex].dataset.swiperBinded,
                );

                previousItem.classList.remove("active");
                targetItem.classList.add("active");
            });
        }
    });
</script>

<section class="testimonials-section d-flex flex-column justify-content-center">
    <!-- testimonials -->
    <div
        class="container position-relative z-1 py-5 mb-md-3 my-lg-3 my-xl-4 my-xxl-5"
    >
        <div class="row py-md-4 py-lg-5">
            <div class="col-md-9 col-lg-7 order-md-2">
                <!-- Swiper slider -->
                <div
                    class="custom-swiper"
                    data-swiper-options={`{
                        "spaceBetween": 40,
                        "loop": true,
                        "bindedContent": true,
                        "autoHeight": true,
                        "pagination": {
                            "el": ".testimonials-count",
                            "type": "fraction"
                        },
                        "navigation": {
                            "prevEl": "#prev-testimonial",
                            "nextEl": "#next-testimonial"
                        }
                    }`}
                >
                    <div class="swiper-wrapper">
                        {
                            testimonials.map((testimonial) => (
                                <div
                                    class="swiper-slide"
                                    data-swiper-binded={testimonial.number}
                                >
                                    <div class="d-flex d-md-none pt-3 mb-3">
                                        <i class="ai-quotes d-md-none text-primary display-3 mt-n2" />
                                        <div class="ps-3">
                                            <h3 class="text-white h5 mb-0">
                                                {testimonial.name}
                                            </h3>
                                            <p class="text-body-primary mb-0">
                                                {testimonial.designation}
                                            </p>
                                        </div>
                                    </div>
                                    <h2 class="mb-lg-4 text-white testimonial-title">
                                        {testimonial.title}
                                    </h2>
                                    <p class="lead mb-0 text-white opacity-70 z-1 testimonial-text">
                                        {testimonial.desc}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-3 offset-lg-1 order-md-1 mt-n3">
                <i class="ai-quotes d-none d-md-block testimonial-quotes-icon ms-n2 mb-1"></i>

                <!-- Content binded to slider (on screens > 768px) -->
                <div class="binded-content h-auto d-none d-md-block">
                    <div class="binded-item h-auto active" id="testimonial-1">
                        <h3 class="h5 mb-1 text-white">{testimonials[0].name}</h3>
                        <p class="text-body-primary mb-0">{testimonials[0].designation}</p>
                    </div>
                    <div class="binded-item h-auto" id="testimonial-2">
                        <h3 class="h5 mb-1 text-white">{testimonials[1].name}</h3>
                        <p class="text-body-primary mb-0">{testimonials[1].designation}</p>
                    </div>
                </div>

                <!-- Swiper controls (Prev / Next) -->
                <div class="d-flex align-items-center pb-2 pb-md-0 pt-4 mt-3">
                    <button
                        class="btn btn-icon btn-sm btn-outline-primary btn-nav-testimonial rounded-circle me-3"
                        type="button"
                        id="prev-testimonial"
                        aria-label="Prev"
                    >
                        <i class="ai-arrow-left"></i>
                    </button>
                    <div
                        class="testimonials-count fw-medium flex-shrink-0 text-center text-white"
                        style="width: 2.5rem;"
                    >
                    </div>
                    <button
                        class="btn btn-icon btn-sm btn-outline-primary btn-nav-testimonial rounded-circle ms-3"
                        type="button"
                        id="next-testimonial"
                        aria-label="Next"
                    >
                        <i class="ai-arrow-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</section>
