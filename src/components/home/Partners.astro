---
import { getEntry } from "astro:content";
import "../../styles/partners-home.css";

const Data = await getEntry("home", "home");
const partners = Data.data.partners;
---

<section class="partners">
	<div class="container solutions-header">
		<div class="expertise-badge">
			<span class="expertise-badge-text">Our Partners</span>
		</div>
		<div class="partners-grid">
			{
				partners.images.map((image) => (
					<img
						class="partner-logo"
						src={image.src}
						alt={image.name}
					/>
				))
			}
		</div>
	</div>
</section>
