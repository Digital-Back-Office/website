---
import { getEntry } from "astro:content";

const Data = await getEntry("home", "home");
const features = Data.data.features;
const cards = features.cards;
---

<style>
    .features {
        position: relative;
        padding: var(--space-20) 0;
        background-image: url(/assets/images/home/star_links.png);
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
    }

    .features::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            180deg,
            rgba(18, 21, 25, 0.95) 0%,
            rgba(18, 21, 25, 0.4) 50%,
            rgba(18, 21, 25, 0.95) 100%
        );
    }

    .features-inner {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(0, 0.6fr) minmax(0, 1fr);
        gap: var(--space-12);
        align-items: start;
    }

    .features-title {
        font-size: clamp(2.25rem, 3vw, 3rem);
        font-weight: var(--font-weight-bold);
        color: var(--text-primary);
        margin-bottom: var(--space-4);
    }

    .faq-list {
        display: grid;
        gap: var(--space-4);
    }

    .faq-item {
        border-radius: var(--radius-xl);
        border: 1px solid var(--border-subtle);
        background-color: rgba(18, 21, 25, 0.9);
        padding: var(--space-5) var(--space-6);
        transition: border-color var(--motion-fast), box-shadow var(--motion-fast);
    }

    .faq-item[open] {
        border-color: var(--border-brand);
        box-shadow: var(--shadow-glow);
    }

    .faq-question {
        cursor: pointer;
        font-size: var(--text-lg);
        font-weight: var(--font-weight-medium);
        color: var(--text-primary);
        list-style: none;
        display: flex;
        align-items: center;
        gap: var(--space-3);
    }

    .faq-question::-webkit-details-marker {
        display: none;
    }

    .faq-icon {
        width: 32px;
        height: 32px;
    }

    .faq-answer {
        margin-top: var(--space-3);
        color: var(--text-secondary);
        line-height: var(--line-height-base);
    }

    @media (max-width: 1024px) {
        .features-inner {
            grid-template-columns: 1fr;
        }
    }
</style>

<section class="features">
    <div class="container">
        <div class="features-inner">
            <div>
                <h2 class="features-title">{features.title}</h2>
            </div>
            <div class="faq-list">
                {cards.map((card) => (
                    <details class="faq-item">
                        <summary class="faq-question">
                            <img class="faq-icon" src={card.img} alt={card.alt} />
                            {card.title}
                        </summary>
                        <p class="faq-answer">{card.info}</p>
                    </details>
                ))}
            </div>
        </div>
    </div>
</section>
