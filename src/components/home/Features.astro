---
import { getEntry } from "astro:content";

const Data = await getEntry("home", "home");
const features = Data.data.features;
const cards = features.cards;
---

<style>
    .features-section {
        position: relative;
        background-image: url(/assets/images/home/star_links.png);
        background-size: cover;
        background-repeat: no-repeat;
        background-position: center;
        padding: 6rem 0;
    }

    .features-section::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(
            180deg,
            #000 0%,
            rgba(0, 0, 0, 0.4) 50%,
            #000 100%
        );
        pointer-events: none;
    }

    .container {
        position: relative;
        z-index: 2;
    }

    .section-title {
        font-size: clamp(2rem, 3.5vw, 2.75rem);
        font-weight: 800;
        margin-bottom: 3.5rem;
        color: #fff;
        letter-spacing: -0.5px;
    }

    .feature-card {
        background: rgba(18, 21, 25, 0.65);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        padding: 2.5rem 2rem;
        width: 100%;
        height: 100%;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .feature-icon {
        height: 48px;
        width: auto;
        object-fit: contain;
        margin-bottom: 1.5rem;
        transition: transform 0.4s ease;
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 0.75rem;
        transition: color 0.3s ease;
    }

    .card-info {
        font-size: 0.95rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.65);
    }

    /* Hover States */
    .item:hover .feature-card {
        transform: translateY(-6px);
        border-color: rgba(82, 206, 199, 0.3);
        background: rgba(18, 21, 25, 0.8);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 20px rgba(82, 206, 199, 0.08);
    }

    .item:hover .feature-icon {
        transform: scale(1.1) rotate(2deg);
    }

    .item:hover .card-title {
        color: #52CEC7;
    }

    @media (min-width: 1024px) {
        .features-section {
            min-height: 80vh;
            display: flex;
            align-items: center;
        }
    }

    @media (max-width: 768px) {
        .features-section {
            padding: 4rem 0;
        }
        .section-title {
            margin-bottom: 2.5rem;
        }
    }
</style>

<section class="features-section" data-bs-theme="dark">
    <div class="container">
        <h2 class="section-title text-center">
            {features.title}
        </h2>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {
                cards.map((card) => (
                    <div class="col item text-center text-sm-start">
                        <div class="feature-card">
                            <img
                                src={card.img}
                                alt={card.alt}
                                class="feature-icon"
                            />
                            <h3 class="card-title">{card.title}</h3>
                            <p class="card-info mb-0">
                                {card.info}
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
