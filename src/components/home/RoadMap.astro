---
import { getEntry } from "astro:content";
import "../../styles/roadmap.css";

const Data = await getEntry("home", "home");
const roadmap = (Data.data as any).roadmap;
---

<section class="roadmap">
  <div class="container">
    <h2 class="roadmap-title">
      {roadmap?.title_1} <span>{roadmap?.title_2}</span>
    </h2>
    <p class="roadmap-subtitle">{roadmap?.sub_title}</p>

    <div class="roadmap-timeline">
      <div class="timeline-trunk">
        <div class="timeline-trunk-pulse"></div>
      </div>

      {roadmap?.cards?.map((card: any, index: number) => {
        const isLeft = index % 2 === 0;
        return (
          <div class={`timeline-row ${isLeft ? 'row-left' : 'row-right'}`}>
            <!-- Central Node -->
            <div class="timeline-node">
              <span class="node-num">{`0${index + 1}`}</span>
              <div class="node-pulse"></div>
            </div>
            
            <!-- Card wrapper -->
            <div class="timeline-card-wrapper">
              <div class="roadmap-card">
                <div class="roadmap-icon">
                  {index === 0 && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                      <line x1="9" y1="9" x2="15" y2="9"></line>
                      <line x1="9" y1="13" x2="15" y2="13"></line>
                      <line x1="9" y1="17" x2="13" y2="17"></line>
                    </svg>
                  )}
                  {index === 1 && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                      <path d="m9 12 2 2 4-4"></path>
                    </svg>
                  )}
                  {index === 2 && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline>
                      <polyline points="16 7 22 7 22 13"></polyline>
                    </svg>
                  )}
                </div>
                
                <h3>{card.heading}</h3>
                <p>{card.description}</p>
              </div>
            </div>

            {roadmap?.cards && index !== roadmap.cards.length - 1 && (
              <div class="arrow-connector d-none d-lg-block">
                <svg
                  class="arrow-svg"
                  width="32"
                  height="32"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#52CEC7"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="9 18 15 12 9 6" />
                </svg>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>
