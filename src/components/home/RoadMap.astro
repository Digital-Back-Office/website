---
import { getEntry } from "astro:content";

const Data = await getEntry("home", "home");
const roadmap = (Data.data as any).roadmap;
---

<style>
  .roadmap {
    padding: var(--space-20) 0;
  }

  .roadmap-title {
    text-align: center;
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-4);
    color: var(--text-primary);
  }

  .roadmap-title span {
    color: var(--brand-cyan);
  }

  .roadmap-subtitle {
    text-align: center;
    font-size: var(--text-lg);
    color: var(--text-secondary);
    margin-bottom: var(--space-12);
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .roadmap-grid {
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .roadmap-card {
    position: relative;
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-brand);
    background: linear-gradient(140deg, rgba(82, 206, 199, 0.14) 0%, rgba(82, 206, 199, 0.04) 100%);
    transition: transform var(--motion-base), box-shadow var(--motion-base), border-color var(--motion-base);
    height: 100%;
  }

  .roadmap-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-glow);
    border-color: rgba(82, 206, 199, 0.6);
  }

  .roadmap-icon {
    margin-bottom: var(--space-5);
  }

  .roadmap-card h3 {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .roadmap-card p {
    font-size: var(--text-base);
    line-height: var(--line-height-base);
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  @media (max-width: 1024px) {
    .roadmap-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="roadmap" data-bs-theme="dark">
  <div class="container">
    <h2 class="roadmap-title">
      {roadmap?.title_1} <span>{roadmap?.title_2}</span>
    </h2>
    <p class="roadmap-subtitle">{roadmap?.sub_title}</p>

    <div class="roadmap-grid">
      {roadmap?.cards?.map((card: any) => (
        <div class="roadmap-card">
          <div class="roadmap-icon">
            <img src={card.icon ?? "/assets/icons/home/readiness.svg"} alt={card.heading} />
          </div>
          <h3>{card.heading}</h3>
          <p>{card.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
