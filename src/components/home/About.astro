---
import { getEntry } from "astro:content";
import Button from "../ui/Button.astro";
import "../../styles/about.css";

const Data = await getEntry("home", "home");
const about = Data.data.about;
---

<section class="about-section position-relative d-flex flex-column justify-content-center">
    <div class="container position-relative py-3 my-2 py-lg-0 my-lg-0">
        <div class="row align-items-center py-4 py-md-5 my-3">
            <div class="col-12 col-lg-6 offset-lg-1 offset-xl-2 order-lg-2 align-items-center mb-5 mb-lg-0">
                <div class="about-graphic-wrapper">
                    <div class="about-graphic-glow"></div>
                    
                    <!-- Orbiting Lines -->
                    <div class="about-orbit-ring orbit-1"></div>
                    <div class="about-orbit-ring orbit-2"></div>
                    
                    <!-- Central Core Hub -->
                    <div class="about-core-hub">
                        <div class="core-hub-inner">
                            <svg class="core-hub-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                                <polyline points="2 17 12 22 22 17"></polyline>
                                <polyline points="2 12 12 17 22 12"></polyline>
                            </svg>
                        </div>
                    </div>
                    
                    <!-- Floating Card 1: Data Analytics -->
                    <div class="about-floating-card about-card-analytics">
                        <div class="card-header-bar">
                            <span class="about-card-title-text">Analytics Engine</span>
                            <span class="card-status-dot"></span>
                        </div>
                        <div class="mini-bar-chart">
                            <div class="bar-col" style="--h: 40%; height: 40%;"></div>
                            <div class="bar-col" style="--h: 70%; height: 70%;"></div>
                            <div class="bar-col active" style="--h: 90%; height: 90%;"></div>
                            <div class="bar-col" style="--h: 55%; height: 55%;"></div>
                        </div>
                    </div>
                    
                    <!-- Floating Card 2: Decision Pipeline -->
                    <div class="about-floating-card about-card-decision">
                        <div class="card-header-bar">
                            <span class="about-card-title-text">Decisioning</span>
                            <span class="card-status-dot"></span>
                        </div>
                        <div class="decision-status">
                            <span class="decision-action-line">Action: Automated</span>
                            <span class="decision-metric-line">Efficiency: +90%</span>
                        </div>
                    </div>
                    
                    <!-- Floating Card 3: Cloud Integrations -->
                    <div class="about-floating-card about-card-integration">
                        <div class="card-header-bar">
                            <span class="about-card-title-text">Integrations</span>
                            <span class="card-status-dot orange"></span>
                        </div>
                        <div class="cloud-logos-row">
                            <span class="cloud-mini-icon">AWS</span>
                            <span class="cloud-mini-icon">Azure</span>
                            <span class="cloud-mini-icon">GCP</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-5 col-xl-4 order-lg-1 text-center text-md-start">
                <h3 class="about-title">{about.title}</h3>
                <p class="about-copy">
                    {about.info_part_1}
                    <br />
                    <br />
                    {about.info_part_2}
                </p>
                <Button href="/services/data-strategy-services" variant="outline" class="mt-3">
                    <span>Learn more</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 4px;">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </Button>
            </div>
        </div>
    </div>
</section>
