---
import { getEntry } from "astro:content";
import Button from "../ui/Button.astro";

const Data = await getEntry("home", "home");
const ai_solutions = Data.data.ai_solutions;

---

<style>
	.ai-section {
		padding: var(--space-20) 0;
	}

	.ai-header {
		text-align: center;
		margin-bottom: var(--space-12);
	}

	.ai-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-2) var(--space-4);
		border-radius: var(--radius-full);
		border: 1px solid var(--border-brand);
		background-color: rgba(82, 206, 199, 0.1);
		color: var(--brand-cyan);
		font-size: var(--text-sm);
		font-weight: var(--font-weight-medium);
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.ai-title {
		font-size: clamp(2.25rem, 4vw, 3.5rem);
		font-weight: var(--font-weight-bold);
		margin: var(--space-6) 0 var(--space-4);
		color: var(--text-primary);
	}

	.ai-subtitle {
		font-size: var(--text-lg);
		color: var(--text-secondary);
		max-width: 820px;
		margin: 0 auto;
	}

	.ai-grid {
		display: grid;
		gap: var(--space-6);
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}

	.ai-card {
		position: relative;
		padding: var(--space-6);
		border-radius: var(--radius-xl);
		border: 1px solid var(--border-subtle);
		background: linear-gradient(160deg, rgba(82, 206, 199, 0.08), rgba(82, 206, 199, 0.02));
		color: var(--text-primary);
		min-height: 100%;
		overflow: hidden;
		transition: transform var(--motion-base), box-shadow var(--motion-base), border-color var(--motion-base);
	}

	.ai-card::after {
		content: "";
		position: absolute;
		inset: -40% -30% auto auto;
		width: 240px;
		height: 240px;
		background: radial-gradient(circle, rgba(82, 206, 199, 0.25) 0%, transparent 70%);
		opacity: 0.4;
	}

	.ai-card:hover {
		transform: translateY(-6px);
		border-color: var(--border-brand);
		box-shadow: var(--shadow-glow);
	}

	.ai-card-body {
		position: relative;
		z-index: 1;
	}

	.ai-icon {
		width: 56px;
		height: 56px;
		border-radius: var(--radius-md);
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(82, 206, 199, 0.15);
		margin-bottom: var(--space-5);
	}

	.ai-card-title {
		font-size: var(--text-xl);
		font-weight: var(--font-weight-bold);
		margin-bottom: var(--space-3);
	}

	.ai-card-desc {
		font-size: var(--text-base);
		line-height: var(--line-height-base);
		color: var(--text-secondary);
		margin-bottom: var(--space-6);
	}

	.ai-card-link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-2);
		color: var(--brand-cyan);
		font-weight: var(--font-weight-medium);
		font-size: var(--text-sm);
	}

	.ai-grid > a:nth-child(1),
	.ai-grid > a:nth-child(4) {
		grid-column: span 2;
	}

	.ai-cta {
		margin-top: var(--space-12);
		display: flex;
		justify-content: center;
	}

	@media (max-width: 1200px) {
		.ai-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.ai-grid > a:nth-child(1),
		.ai-grid > a:nth-child(4) {
			grid-column: span 1;
		}
	}

	@media (max-width: 768px) {
		.ai-section {
			padding: var(--space-16) 0;
		}

		.ai-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<!-- AI Solutions Showcase Section -->
<section class="ai-section" data-bs-theme="dark">
	<div class="container">
		<div class="ai-header">
			<div class="ai-eyebrow">Our Expertise</div>
			<h2 class="ai-title">{ai_solutions.title}</h2>
			<p class="ai-subtitle">{ai_solutions.sub_title}</p>
		</div>

		<div class="ai-grid">
			{ai_solutions.cards?.map((card: any) => (
				<a
					href={card.link ?? `/services/ai-solutions#${card.id ?? ""}`}
					class="text-decoration-none"
				>
					<div class="ai-card">
						<div class="ai-card-body">
							<div class="ai-icon">
								<img src={card.icon ?? "/assets/icons/home/startegy.svg"} alt={card.alt} width="36" height="36" />
							</div>
							<h3 class="ai-card-title">{card.heading}</h3>
							<p class="ai-card-desc">{card.description}</p>
							<span class="ai-card-link">
								<span>Learn more</span>
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<line x1="5" y1="12" x2="19" y2="12"></line>
									<polyline points="12 5 19 12 12 19"></polyline>
								</svg>
							</span>
						</div>
					</div>
				</a>
			))}
		</div>

		<div class="ai-cta">
			<Button href="/services/ai-solutions" size="lg">
				{ai_solutions.cta_text}
			</Button>
		</div>
	</div>
</section>
