---
import { getEntry } from "astro:content"

const Data = await getEntry("home", "home");
const ai_solutions = Data.data.ai_solutions;
---

<style>
	.solutions-section {
		padding: 6rem 0;
		background-color: transparent;
	}

	.badge-container {
		display: inline-block;
		background-color: rgba(82, 206, 199, 0.08);
		border-radius: 50px;
		padding: 0.5rem 1.5rem;
		margin-bottom: 1.5rem;
		border: 1px solid rgba(82, 206, 199, 0.2);
	}

	.badge-text {
		font-size: 0.85rem;
		font-weight: 600;
		color: #52CEC7;
		letter-spacing: 1px;
		text-transform: uppercase;
	}

	.section-title {
		font-size: clamp(2.25rem, 4vw, 3rem);
		font-weight: 800;
		margin-bottom: 1.25rem;
		color: #fff;
		letter-spacing: -0.5px;
	}

	.section-subtitle {
		font-size: 1.15rem;
		color: rgba(255, 255, 255, 0.7);
		max-width: 750px;
		margin: 0 auto;
		line-height: 1.6;
	}

	.solution-card-link {
		text-decoration: none;
		display: block;
		height: 100%;
	}

	.solution-card {
		background: rgba(255, 255, 255, 0.02);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid rgba(82, 206, 199, 0.15);
		border-radius: 18px;
		padding: 2.25rem 2rem;
		height: 100%;
		transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
		position: relative;
		overflow: hidden;
	}

	.card-glow {
		position: absolute;
		top: -50%;
		right: -50%;
		width: 200%;
		height: 200%;
		background: radial-gradient(circle, rgba(82, 206, 199, 0.08) 0%, transparent 65%);
		opacity: 0.4;
		transition: opacity 0.4s ease;
		pointer-events: none;
	}

	.card-content {
		position: relative;
		z-index: 1;
	}

	.icon-wrapper {
		width: 60px;
		height: 60px;
		background: rgba(82, 206, 199, 0.1);
		border: 1px solid rgba(82, 206, 199, 0.2);
		border-radius: 14px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 1.75rem;
		transition: all 0.4s ease;
	}

	.icon-img {
		width: 38px;
		height: 38px;
		object-fit: contain;
		transition: transform 0.4s ease;
	}

	.card-heading {
		font-size: 1.35rem;
		font-weight: 700;
		color: #fff;
		margin-bottom: 0.85rem;
		transition: color 0.3s ease;
	}

	.card-desc {
		font-size: 0.95rem;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.65);
		margin-bottom: 1.75rem;
	}

	.learn-more-btn {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: #52CEC7;
		font-weight: 600;
		font-size: 0.9rem;
		transition: gap 0.3s ease;
	}

	.learn-more-arrow {
		transition: transform 0.3s ease;
	}

	/* Solution Card Hover Effects */
	.solution-card-link:hover .solution-card {
		transform: translateY(-8px);
		border-color: rgba(82, 206, 199, 0.45);
		background: rgba(82, 206, 199, 0.03);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 30px rgba(82, 206, 199, 0.1);
	}

	.solution-card-link:hover .card-glow {
		opacity: 0.8;
	}

	.solution-card-link:hover .icon-wrapper {
		background: rgba(82, 206, 199, 0.2);
		border-color: rgba(82, 206, 199, 0.4);
		box-shadow: 0 0 15px rgba(82, 206, 199, 0.25);
	}

	.solution-card-link:hover .icon-img {
		transform: scale(1.08);
	}

	.solution-card-link:hover .card-heading {
		color: #52CEC7;
	}

	.solution-card-link:hover .learn-more-btn {
		gap: 0.75rem;
	}

	.solution-card-link:hover .learn-more-arrow {
		transform: translateX(3px);
	}

	/* CTA Button styling */
	.cta-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1.05rem;
		padding: 0.95rem 2.5rem;
		font-weight: 600;
		background: linear-gradient(135deg, #52CEC7 0%, #3BA9A3 100%);
		color: #000;
		transition: all 0.3s ease;
		border-radius: 50px;
		text-decoration: none;
		box-shadow: 0 4px 15px rgba(82, 206, 199, 0.25);
	}

	.cta-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 25px rgba(82, 206, 199, 0.45);
		background: linear-gradient(135deg, #3BA9A3 0%, #52CEC7 100%);
		color: #000;
	}

	@media (max-width: 768px) {
		.solutions-section {
			padding: 4rem 0;
		}
		.cta-btn {
			font-size: 1rem !important;
			padding: 0.85rem 2rem !important;
		}
	}
</style>

<!-- AI Solutions Showcase Section -->
<section class="solutions-section" data-bs-theme="dark">
	<div class="container">
		<div class="text-center mb-5">
			<div class="badge-container">
				<span class="badge-text">Our Expertise</span>
			</div>
			<h2 class="section-title">
				{ai_solutions.title}
			</h2>
			<p class="section-subtitle">
				{ai_solutions.sub_title}
			</p>
		</div>

		<div class="row g-4">
			{ai_solutions.cards?.map((card: any) => (
				<div class="col-lg-3 col-md-6">
					<a href={card.link ?? `/services/ai-solutions#${card.id ?? ""}`} class="solution-card-link">
						<div class="solution-card">
							<div class="card-glow"></div>

							<div class="card-content">
								<div class="icon-wrapper">
									<img src={card.icon ?? "/assets/icons/home/startegy.svg"} alt={card.alt} class="icon-img" />
								</div>

								<h3 class="card-heading">
									{card.heading}
								</h3>

								<p class="card-desc">
									{card.description}
								</p>

								<div class="learn-more-btn">
									<span>Learn more</span>
									<svg class="learn-more-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<line x1="5" y1="12" x2="19" y2="12"></line>
										<polyline points="12 5 19 12 12 19"></polyline>
									</svg>
								</div>
							</div>
						</div>
					</a>
				</div>
			))}
		</div>

		<!-- CTA Section -->
		<div class="text-center mt-5 pt-3">
			<a href="/services/ai-solutions" class="cta-btn">
				{ai_solutions.cta_text}
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="5" y1="12" x2="19" y2="12"></line>
					<polyline points="12 5 19 12 12 19"></polyline>
				</svg>
			</a>
		</div>
	</div>
</section>
