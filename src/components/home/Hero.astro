<script>
  document.addEventListener('DOMContentLoaded', () => {
    const heroForm = document.getElementById('hero-email-form');
    heroForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('hero-email') as HTMLInputElement;
      const targetEmailInput = document.getElementById('book-email') as HTMLInputElement;
      
      if (emailInput && targetEmailInput) {
        targetEmailInput.value = emailInput.value.trim();
        targetEmailInput.dispatchEvent(new Event('input', { bubbles: true }));
      }
      
      const targetSection = document.getElementById('book-a-call-section');
      if (targetSection) {
        targetSection.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>
