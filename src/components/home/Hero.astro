---
import { getEntry } from "astro:content";

const Data = await getEntry("home", "home");
const hero = Data.data.hero;

import Consultation_form from "../common/ConsultationForm.astro";
---

<style>
    .hero-section {
        position: relative;
        overflow: hidden;
        padding: var(--space-24) 0;
        min-height: max-content;
    }

    .hero-section * {
        z-index: 3;
    }

    /* Animated gradient background elements */
    .gradient-orb-1 {
        position: absolute;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(82, 206, 199, 0.25) 0%, transparent 70%);
        border-radius: 50%;
        top: -200px;
        left: -100px;
        z-index: 1;
        animation: float 8s ease-in-out infinite;
    }

    .gradient-orb-2 {
        position: absolute;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(238, 191, 46, 0.2) 0%, transparent 70%);
        border-radius: 50%;
        bottom: -150px;
        right: -100px;
        z-index: 1;
        animation: float 10s ease-in-out infinite reverse;
    }

    .gradient-orb-3 {
        position: absolute;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(82, 206, 199, 0.15) 0%, transparent 70%);
        border-radius: 50%;
        top: 50%;
        right: 10%;
        z-index: 1;
        animation: float 12s ease-in-out infinite;
    }

    .hero-grid {
        display: grid;
        gap: var(--space-12);
        align-items: center;
    }

    .hero-copy {
        max-width: 560px;
        margin: 0 auto;
    }

    @keyframes float {
        0%, 100% {
            transform: translateY(0) scale(1);
        }
        50% {
            transform: translateY(-30px) scale(1.05);
        }
    }

    .hero-title {
        font-size: clamp(2.75rem, 4vw, 4.5rem);
        line-height: var(--line-height-tight);
        margin-bottom: var(--space-6);
    }

    .gradient-text {
        background: linear-gradient(135deg, var(--brand-cyan) 0%, var(--brand-yellow) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 800;
        display: inline-block;
        animation: shimmer 3s ease-in-out infinite;
    }

    @keyframes shimmer {
        0%, 100% {
            background-position: 0% 50%;
        }
        50% {
            background-position: 100% 50%;
        }
    }

    .ai-badge {
        display: inline-block;
        background: linear-gradient(135deg, rgba(82, 206, 199, 0.18) 0%, rgba(238, 191, 46, 0.12) 100%);
        border: 1px solid var(--border-brand);
        border-radius: var(--radius-full);
        padding: var(--space-2) var(--space-4);
        font-size: var(--text-sm);
        font-weight: var(--font-weight-medium);
        color: var(--brand-cyan);
        margin-bottom: var(--space-6);
        animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% {
            box-shadow: 0 0 20px rgba(82, 206, 199, 0.3);
        }
        50% {
            box-shadow: 0 0 40px rgba(82, 206, 199, 0.5);
        }
    }

    .hero-description {
        font-size: var(--text-lg);
        line-height: var(--line-height-relaxed);
        color: var(--text-secondary);
        margin-bottom: var(--space-8);
    }

    .contact-form {
        background: var(--bg-glass) !important;
        border-radius: var(--radius-2xl);
        box-shadow: var(--shadow-lg), var(--shadow-glow);
        border: 1px solid var(--border-brand);
        width: fit-content;
        height: fit-content;
        backdrop-filter: blur(12px);
    }

    .card {
        form {
            padding: 2rem;
            height: 100%;
        }

        .card-title {
            font-size: 1.1rem;
            color: var(--brand-cyan) !important;
        }

        .form-label {
            font-size: 0.8rem !important;
            color: var(--brand-cyan) !important;
        }

        .form-control {
            border-radius: 0.5rem !important;
            line-height: 1 !important;
            background-color: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border-brand);
            color: #fff;

            &:focus {
                background-color: rgba(255, 255, 255, 0.08);
                border-color: var(--brand-cyan);
                box-shadow: 0 0 20px rgba(82, 206, 199, 0.2);
            }
        }

        .book-btn {
            background: linear-gradient(135deg, var(--brand-cyan) 0%, var(--brand-cyan-hover) 100%);
            border-radius: 0.5rem;
            width: 100% !important;
            font-weight: 600;
            padding: 0.75rem;
            transition: all var(--motion-base);
            box-shadow: 0 4px 15px rgba(82, 206, 199, 0.3);

            &:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(82, 206, 199, 0.4);
                background: linear-gradient(135deg, var(--brand-cyan-hover) 0%, var(--brand-cyan) 100%);
            }
        }

        @media(max-width: 425px) {
            form {
                padding: 2rem 1rem;
            }
        }
    }

    /* Floating AI icons */
    .ai-icon {
        position: absolute;
        z-index: 2;
        opacity: 0.15;
        animation: floatIcon 6s ease-in-out infinite;
    }

    @keyframes floatIcon {
        0%, 100% {
            transform: translateY(0) rotate(0deg);
        }
        50% {
            transform: translateY(-20px) rotate(5deg);
        }
    }

    @media (min-width: 1024px) {
        .hero-section {
            min-height: 90vh;
        }

        .hero-grid {
            grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
            gap: var(--space-16);
        }
    }

    @media (max-width: 1024px) {
        .hero-section {
            padding-top: var(--space-20);
            padding-bottom: var(--space-16);
        }

        .gradient-orb-1, .gradient-orb-2, .gradient-orb-3 {
            width: 300px;
            height: 300px;
        }   
    }

    @media (max-width: 576px) {
        .ai-badge {
            margin-top: 30px !important;
        }
    }
</style>

<section class="hero-section d-flex align-items-center">
    <!-- Animated gradient orbs -->
    <div class="gradient-orb-1"></div>
    <!-- <div class="gradient-orb-2"></div> -->
    <div class="gradient-orb-3"></div>

    <div class="container position-relative my-auto">
        <div class="hero-grid">
            <div class="hero-copy text-center text-lg-start">
                    <div class="ai-badge">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; margin-right: 0.5rem; vertical-align: middle;">
                            <circle cx="12" cy="12" r="10"></circle>
                            <circle cx="12" cy="12" r="6"></circle>
                            <circle cx="12" cy="12" r="2"></circle>
                        </svg>
                        {hero.pill_text}
                    </div>
                    <h1 class="hero-title text-light">
                        {hero.title_part_1}
                        <br />
                        <span class="gradient-text">{hero.title_part_2}</span>
                    </h1>
                    <p class="hero-description">
                        {hero.info}
                    </p>
            </div>
            <div class="contact-div">
                <!-- Contact form -->
                <div class="card contact-form border-0">
                    <Consultation_form />
                </div>
            </div>
        </div>
    </div>
</section>
