---
import { getEntry } from "astro:content";

const Data = await getEntry("home", "home");
const hero = Data.data.hero;

import Consultation_form from "../common/ConsultationForm.astro";
import Button from "../ui/Button.astro";
---

<style>
    .hero-section {
        position: relative;
        overflow: hidden;
        padding: var(--space-24) 0;
        min-height: 92vh;
        display: flex;
        align-items: center;
        background-color: var(--bg-base);
        /* Subtle technical developer background grid */
        background-image: 
            radial-gradient(rgba(15, 23, 42, 0.05) 1.2px, transparent 1.2px);
        background-size: 32px 32px;
    }

    /* Radial gradient mask to fade the grid nicely at edges */
    .hero-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 50% 40%, transparent 20%, var(--bg-base) 80%);
        pointer-events: none;
        z-index: 2;
    }

    .hero-section * {
        z-index: 3;
    }

    /* Minimal soft background glow - no yellow orb, very quiet cyan blur */
    .gradient-orb-cyan {
        position: absolute;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(82, 206, 199, 0.08) 0%, transparent 70%);
        border-radius: 50%;
        top: 20%;
        right: 5%;
        z-index: 1;
        filter: blur(50px);
        pointer-events: none;
    }

    .hero-copy-col {
        display: flex;
        flex-direction: column;
        justify-content: center;
        text-align: left;
        padding-right: var(--space-6);
    }

    .ai-badge-wrapper {
        margin-bottom: var(--space-5);
    }

    .ai-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        background: rgba(48, 186, 186, 0.06);
        border: 1px solid rgba(48, 186, 186, 0.25);
        border-radius: var(--radius-full);
        padding: 0.4rem 0.95rem;
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--brand-teal-deep);
        backdrop-filter: blur(8px);
        transition: all var(--motion-base);
    }

    .ai-badge:hover {
        transform: translateY(-1.5px);
        background: rgba(48, 186, 186, 0.1);
        border-color: rgba(48, 186, 186, 0.4);
    }

    .ai-badge-dot {
        width: 8px;
        height: 8px;
        background-color: var(--brand-teal-alt);
        border-radius: 50%;
        position: relative;
    }

    .ai-badge-dot::after {
        content: '';
        position: absolute;
        inset: -4px;
        border-radius: 50%;
        background-color: var(--brand-teal-alt);
        opacity: 0.5;
        animation: badgePing 2.2s cubic-bezier(0, 0, 0.2, 1) infinite;
    }

    @keyframes badgePing {
        0% {
            transform: scale(1);
            opacity: 0.7;
        }
        70%, 100% {
            transform: scale(2.6);
            opacity: 0;
        }
    }

    .hero-title {
        color: var(--text-primary);
        font-size: clamp(2.6rem, 5vw, 4.25rem);
        font-weight: 800;
        line-height: 1.12;
        letter-spacing: -0.025em;
        margin-bottom: var(--space-6);
    }

    /* Clean Solid Brand Color Highlight instead of Gradient Text */
    .gradient-text {
        background: linear-gradient(135deg, var(--brand-cyan) 0%, var(--brand-teal-deep) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        font-weight: 800;
        display: inline-block;
        animation: shimmer 3s ease-in-out infinite;
    }

    .hero-description {
        font-size: clamp(1.05rem, 1.2vw, 1.2rem);
        line-height: 1.65;
        color: var(--text-secondary);
        margin-bottom: var(--space-8);
        max-width: 640px;
    }

    /* CTA buttons styling */
    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-4);
        margin-bottom: var(--space-12);
        z-index: 10;
    }



    /* Trust indicators styling */
    .hero-trust {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    .trust-label {
        font-size: var(--text-xs);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-muted);
    }

    .trust-logos {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
        align-items: center;
    }

    .trust-badge {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text-muted);
        background: rgba(15, 23, 42, 0.04);
        padding: 0.35rem 0.8rem;
        border-radius: var(--radius-md);
        border: 1px solid var(--border-subtle);
        transition: all var(--motion-base);
    }

    .trust-badge:hover {
        background: rgba(48, 186, 186, 0.08);
        border-color: var(--border-brand);
        color: var(--brand-teal-deep);
        transform: translateY(-1.5px);
    }

    /* Premium AI Orchestrator Dashboard Visualizer on Right Column */
    .hero-visual-wrapper {
        position: relative;
        width: 100%;
        max-width: 580px;
        aspect-ratio: 1.1 / 1;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 5;
        perspective: 1200px;
    }

    .visual-glow {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 50% 50%, rgba(82, 206, 199, 0.1) 0%, transparent 70%);
        filter: blur(40px);
        z-index: 1;
        pointer-events: none;
    }

    .dashboard-canvas {
        position: relative;
        width: 100%;
        height: 100%;
        transform-style: preserve-3d;
        transform: rotateX(16deg) rotateY(-18deg) rotateZ(6deg) translate3d(0, 0, 0);
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        z-index: 2;
    }

    .dashboard-canvas:hover {
        transform: rotateX(10deg) rotateY(-10deg) rotateZ(3deg) translate3d(0, 0, 0);
    }

    .main-dashboard-panel {
        position: absolute;
        inset: 6% 6% 12% 6%;
        background: rgba(11, 15, 25, 0.96);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--radius-xl);
        box-shadow: 
            0 30px 60px rgba(15, 23, 42, 0.25),
            inset 0 0 0 1px rgba(255, 255, 255, 0.03);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transform-style: preserve-3d;
        transform: translateZ(0);
    }

    .panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.65rem 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(15, 23, 42, 0.3);
    }

    .window-dots {
        display: flex;
        gap: 6px;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .dot-close { background-color: #ef4444; opacity: 0.85; }
    .dot-minimize { background-color: #f59e0b; opacity: 0.85; }
    .dot-maximize { background-color: #10b981; opacity: 0.85; }

    .panel-title {
        font-family: monospace;
        font-size: 10px;
        color: rgba(255, 255, 255, 0.35);
        letter-spacing: 0.05em;
    }

    .panel-status {
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background-color: var(--brand-teal-alt);
        box-shadow: 0 0 8px var(--brand-teal-alt);
        animation: statusPulse 2s ease-in-out infinite;
    }

    .status-text {
        font-size: 8px;
        font-weight: 700;
        color: var(--brand-teal-alt);
        letter-spacing: 0.06em;
    }

    @keyframes statusPulse {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 1; }
    }

    .panel-body {
        display: flex;
        flex: 1;
        min-height: 0;
    }

    .panel-sidebar {
        width: 44px;
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        padding: var(--space-4) 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-3);
        background: rgba(15, 23, 42, 0.2);
    }

    .sidebar-item {
        width: 16px;
        height: 16px;
        border-radius: 4px;
        background: rgba(255, 255, 255, 0.04);
    }

    .sidebar-item.active {
        background: rgba(48, 186, 186, 0.15);
        border: 1px solid rgba(48, 186, 186, 0.3);
    }

    .panel-content {
        flex: 1;
        padding: 0.9rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        min-height: 0;
        justify-content: space-between;
    }

    .pipeline-section {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .pipeline-title {
        font-size: 9px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .pipeline-flow {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255, 255, 255, 0.015);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: var(--radius-md);
        padding: 0.5rem 0.75rem;
    }

    .flow-node {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3px;
    }

    .node-icon-wrapper {
        width: 26px;
        height: 26px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(255, 255, 255, 0.4);
    }

    .node-icon-wrapper.active {
        background: rgba(48, 186, 186, 0.12);
        border-color: rgba(48, 186, 186, 0.35);
        color: var(--brand-teal-alt);
        box-shadow: 0 0 10px rgba(48, 186, 186, 0.15);
    }

    .icon-pulse {
        animation: iconPulse 2.5s infinite ease-in-out;
    }

    @keyframes iconPulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.08); }
    }

    .node-label {
        font-size: 8px;
        color: rgba(255, 255, 255, 0.45);
        font-weight: 500;
    }

    .flow-line {
        flex: 1;
        margin: 0 0.5rem;
        height: 10px;
        display: flex;
        align-items: center;
    }

    .line-svg {
        width: 100%;
        height: 100%;
        overflow: visible;
    }

    .flowing-dot-1 {
        animation: flowDot 2.2s infinite linear;
    }

    .flowing-dot-2 {
        animation: flowDot 1.9s infinite linear;
    }

    @keyframes flowDot {
        to { cx: 60; }
    }

    .content-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 0.75rem;
        flex: 1;
        min-height: 0;
    }

    .dashboard-card {
        background: rgba(255, 255, 255, 0.01);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: var(--radius-md);
        padding: 0.6rem;
        display: flex;
        flex-direction: column;
    }

    .chart-card {
        justify-content: flex-start;
        gap: 0.4rem;
    }

    .card-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .meta-title {
        font-size: 8.5px;
        color: rgba(255, 255, 255, 0.4);
        font-weight: 600;
    }

    .meta-val {
        font-size: 8.5px;
        color: var(--brand-teal-alt);
        font-weight: 700;
    }

    .sparkline-chart {
        width: 100%;
        height: 38px;
        overflow: visible;
        margin-top: auto;
    }

    .sparkline-path {
        stroke-dasharray: 200;
        stroke-dashoffset: 200;
        animation: drawSparkline 3.5s forwards ease-in-out;
    }

    .sparkline-predictive-path {
        stroke-dasharray: 4, 3;
        animation: predictiveFlow 15s linear infinite;
    }

    @keyframes predictiveFlow {
        to {
            stroke-dashoffset: -100;
        }
    }

    .sparkline-path-fill {
        opacity: 0.12;
    }

    @keyframes drawSparkline {
        to { stroke-dashoffset: 0; }
    }

    .chart-pulse-dot {
        animation: pulseDot 2s infinite ease-in-out;
    }

    @keyframes pulseDot {
        0%, 100% { r: 2px; opacity: 0.6; }
        50% { r: 3.2px; opacity: 1; }
    }

    .console-card {
        font-family: monospace;
        font-size: 8px;
        justify-content: flex-start;
        gap: 3px;
        background: rgba(0, 0, 0, 0.2);
    }

    .console-header {
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        padding-bottom: 3px;
        margin-bottom: 2px;
        display: flex;
        align-items: center;
    }

    .terminal-lbl {
        color: rgba(255, 255, 255, 0.3);
        font-weight: 600;
        font-size: 7.5px;
    }

    .console-body {
        display: flex;
        flex-direction: column;
        gap: 2px;
        overflow: hidden;
    }

    .log-line {
        color: rgba(255, 255, 255, 0.4);
        white-space: nowrap;
        text-overflow: ellipsis;
        overflow: hidden;
        line-height: 1.25;
    }

    .log-line.green { color: #10b981; }
    .log-line.cyan { color: var(--brand-teal-alt); }

    .t-prompt {
        color: var(--brand-cyan);
        margin-right: 2px;
        font-weight: bold;
    }

    /* Floating glassmorphic cards wrapper and components */
    .floating-cards-container {
        position: absolute;
        inset: 0;
        transform-style: preserve-3d;
        pointer-events: none;
    }

    .floating-card-wrapper {
        position: absolute;
        z-index: 10;
        transform-style: preserve-3d;
        pointer-events: none;
    }

    .floating-card {
        pointer-events: auto;
        background-color: rgba(255, 255, 255, 0.88);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(48, 186, 186, 0.16);
        border-radius: var(--radius-lg);
        padding: 0.65rem 0.95rem;
        box-shadow: 
            0 10px 25px rgba(15, 23, 42, 0.06),
            0 1px 3px rgba(15, 23, 42, 0.02);
        display: flex;
        align-items: center;
        gap: 0.65rem;
        transition: 
            border-color var(--motion-base),
            box-shadow var(--motion-base),
            scale var(--motion-base);
    }

    .floating-card:hover {
        border-color: rgba(48, 186, 186, 0.4);
        box-shadow: var(--shadow-glow), 0 12px 30px rgba(15, 23, 42, 0.09);
        scale: 1.03;
    }

    .floating-card-icon {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
    }

    .icon-cyan {
        background: rgba(48, 186, 186, 0.08);
        color: var(--brand-teal-deep);
    }

    .icon-yellow {
        background: rgba(238, 191, 46, 0.08);
        color: #b78a0c;
    }

    .floating-card-info {
        display: flex;
        flex-direction: column;
    }

    .floating-card-num {
        font-size: 1rem;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1.15;
    }

    .floating-card-lbl {
        font-size: 0.6rem;
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    /* Positioning and Float Animations */
    .wrapper-top-left {
        top: 4%;
        left: -2%;
        transform: translateZ(75px);
        animation: floatCard-TL 6.5s ease-in-out infinite;
    }

    .wrapper-top-right {
        top: 14%;
        right: -4%;
        transform: translateZ(100px);
        animation: floatCard-TR 7.5s ease-in-out infinite 0.8s;
    }

    .wrapper-bottom-left {
        bottom: 12%;
        left: -6%;
        transform: translateZ(90px);
        animation: floatCard-BL 8.5s ease-in-out infinite 1.8s;
    }

    .wrapper-bottom-right {
        bottom: 6%;
        right: 0%;
        transform: translateZ(80px);
        animation: floatCard-BR 7s ease-in-out infinite 0.4s;
    }

    @keyframes floatCard-TL {
        0%, 100% { transform: translate3d(0, 0, 75px); }
        50% { transform: translate3d(0, -6px, 75px); }
    }
    @keyframes floatCard-TR {
        0%, 100% { transform: translate3d(0, 0, 100px); }
        50% { transform: translate3d(0, -7px, 100px); }
    }
    @keyframes floatCard-BL {
        0%, 100% { transform: translate3d(0, 0, 90px); }
        50% { transform: translate3d(0, -8px, 90px); }
    }
    @keyframes floatCard-BR {
        0%, 100% { transform: translate3d(0, 0, 80px); }
        50% { transform: translate3d(0, -6px, 80px); }
    }

    /* Desktop and larger breakpoint adjustments */
    @media (min-width: 1024px) {
        .hero-section {
            min-height: 94vh;
        }
    }

    /* Mobile, tablet adjustments */
    @media (max-width: 1023.98px) {
        .hero-section {
            padding-top: var(--space-32);
            padding-bottom: var(--space-20);
        }

        .hero-copy-col {
            text-align: center;
            align-items: center;
            padding-right: 0;
            margin-bottom: var(--space-16);
        }

        .hero-actions {
            justify-content: center;
        }

        .trust-logos {
            justify-content: center;
        }

        .hero-visual-wrapper {
            max-width: 540px;
            aspect-ratio: auto;
            height: auto;
            perspective: none;
            margin-top: var(--space-8);
        }

        .dashboard-canvas {
            transform: none !important;
            transform-style: flat;
            display: flex;
            flex-direction: column;
            gap: var(--space-4);
        }

        .main-dashboard-panel {
            position: relative;
            inset: auto;
            width: 100%;
            height: 300px;
            transform: none !important;
        }

        .floating-cards-container {
            position: relative;
            inset: auto;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: var(--space-3);
            width: 100%;
            pointer-events: auto;
            transform-style: flat;
            margin-top: var(--space-2);
        }

        .floating-card-wrapper {
            position: static !important;
            transform: none !important;
            animation: none !important;
            width: 100%;
        }

        .floating-card {
            width: 100%;
            justify-content: flex-start;
        }
    }

    @media (max-width: 576px) {
        .ai-badge-wrapper {
            margin-top: 15px !important;
        }

        .hero-title {
            font-size: 2.3rem;
        }

        .hero-actions {
            flex-direction: column;
            align-items: stretch;
            width: 100%;
        }

        .hero-actions .btn {
            width: 100%;
            justify-content: center;
        }

        .floating-cards-container {
            grid-template-columns: 1fr;
        }

        .floating-card-num {
            font-size: 0.95rem;
        }

        .floating-card-lbl {
            font-size: 0.65rem;
        }
    }

    /* Hero Email Input CTA Styling */
    .hero-email-form {
        display: flex;
        align-items: center;
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        border-radius: 14px;
        padding: 0.35rem;
        max-width: 520px;
        width: 100%;
        margin-bottom: var(--space-10);
        box-shadow: 0 4px 15px rgba(15, 23, 42, 0.02);
        transition: border-color var(--motion-base), box-shadow var(--motion-base);
    }

    .hero-email-form:focus-within {
        border-color: var(--brand-cyan);
        box-shadow: 0 0 0 4px rgba(48, 186, 186, 0.15);
    }

    .hero-email-input {
        flex: 1;
        border: none;
        background: transparent;
        padding: 0.8rem 1.2rem;
        font-size: 0.95rem;
        color: #0f172a;
        outline: none;
        width: 100%;
    }

    .hero-email-input::placeholder {
        color: #94a3b8;
    }

    .hero-email-btn {
        background: linear-gradient(135deg, var(--brand-cyan) 0%, #2fb7b8 100%);
        border: none;
        border-radius: 10px;
        color: #ffffff;
        font-size: 0.95rem;
        font-weight: 700;
        padding: 0.85rem 1.75rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        white-space: nowrap;
        cursor: pointer;
        transition: opacity var(--motion-base), box-shadow var(--motion-base);
    }

    .hero-email-btn:hover {
        opacity: 0.95;
        box-shadow: 0 4px 12px rgba(48, 186, 186, 0.3);
    }

    .hero-email-btn svg {
        transition: transform var(--motion-base);
    }

    /* Make responsive for mobile viewports */
    @media (max-width: 576px) {
        .hero-email-form {
            flex-direction: column;
            gap: 0.5rem;
            padding: 0.5rem;
            background: transparent;
            border: none;
            box-shadow: none;
        }

        .hero-email-form:focus-within {
            box-shadow: none;
        }

        .hero-email-input {
            background-color: #ffffff;
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            padding: 0.9rem 1.2rem;
        }

        .hero-email-input:focus {
            border-color: var(--brand-cyan);
            box-shadow: 0 0 0 4px rgba(48, 186, 186, 0.15);
        }

        .hero-email-btn {
            width: 100%;
            justify-content: center;
            padding: 0.9rem 1.5rem;
            border-radius: 12px;
        }
    }
</style>

<section class="hero-section">
    <div class="gradient-orb-cyan"></div>

    <div class="container position-relative">
        <div class="row align-items-center">
            
            <!-- Left Column: Copy & Actions -->
            <div class="col-lg-6 col-xl-6 hero-copy-col">
                <div class="ai-badge-wrapper">
                    <span class="ai-badge">
                        <span class="ai-badge-dot"></span>
                        {hero.pill_text}
                    </span>
                </div>
                
                <h1 class="hero-title">
                    {hero.title_part_1}
                    <span class="gradient-text">{hero.title_part_2}</span>
                </h1>
                
                <p class="hero-description">
                    {hero.info}
                </p>
                
                <form class="hero-email-form" id="hero-email-form">
                    <input 
                        type="email" 
                        placeholder="Enter your email address" 
                        class="hero-email-input" 
                        required 
                        id="hero-email" 
                    />
