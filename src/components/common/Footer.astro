---
import "../../styles/footer.css";
---

<footer class="footer" data-pagefind-ignore>
  <div class="container">
    <div class="row g-5 align-items-start">
      <!-- Brand Column -->
      <div class="col-lg-4 col-md-12 footer-brand-col">
        <a class="footer-brand-logo" href="/" aria-label="Digital Back Office">
          <img
            src="/assets/images/dbo_1.png"
            alt="Digital Back Office Logo"
            style="width: 110px; height: 50px; object-fit: contain;"
          />
        </a>
        <p class="footer-brand-desc">
          We deliver business efficiency; We Love Data!
        </p>
        <div class="footer-social-wrapper">
          <a
            class="footer-social-link"
            href="https://x.com/Digital_B_O"
            aria-label="X"
            target="_blank"
            rel="noopener"
          >
            <i class="ai-x"></i>
          </a>
          <a
            class="footer-social-link"
            href="https://www.linkedin.com/company/digital-back-office/"
            aria-label="LinkedIn"
            target="_blank"
            rel="noopener"
          >
            <i class="ai-linkedin"></i>
          </a>
        </div>
      </div>

      <!-- Navigation Columns -->
      <div class="col-lg-2 col-md-3 col-6">
        <h6 class="footer-title">Services</h6>
        <ul class="footer-list">
          <li>
            <a class="footer-link" href="/services/ai-solutions" title="AI transformation">
              AI transformation
            </a>
          </li>
          <li>
            <a class="footer-link" href="/services/data-strategy-services" title="Data Strategy">
              Data Strategy
            </a>
          </li>
          <li>
            <a class="footer-link" href="/services/data-engineering-services" title="Data Engineering">
              Data Engineering
            </a>
          </li>
          <li>
            <a class="footer-link" href="/services/data-science" title="Data Science">
              Data Science
            </a>
          </li>
        </ul>
      </div>

      <div class="col-lg-2 col-md-3 col-6">
        <h6 class="footer-title">Industries</h6>
        <ul class="footer-list">
          <li>
            <a class="footer-link" href="/industry/finance-and-insurance" title="Finance">
              Finance
            </a>
          </li>
          <li>
            <a class="footer-link" href="/industry/healthcare-life-sciences" title="Healthcare">
              Healthcare
            </a>
          </li>
          <li>
            <a class="footer-link" href="/industry/retail-and-e-commerce" title="Retail">
              Retail
            </a>
          </li>
          <li>
            <a class="footer-link" href="/industry/technology-media-and-telecom" title="Media">
              Media
            </a>
          </li>
          <li>
            <a class="footer-link" href="/industry/startups" title="Startups">
              Startups
            </a>
          </li>
        </ul>
      </div>

      <div class="col-lg-2 col-md-3 col-6">
        <h6 class="footer-title">Company</h6>
        <ul class="footer-list">
          <li>
            <a class="footer-link" href="/about-us" title="About">
              About
            </a>
          </li>
          <li>
            <a class="footer-link" href="/privacy-policy" title="Privacy policy">
              Privacy policy
            </a>
          </li>
          <li>
            <a class="footer-link" href="/terms-of-use" title="Terms of Use">
              Terms of Use
            </a>
          </li>
          <li>
            <a class="footer-link" href="/legal-slavery" title="Modern Slavery Statement">
              Modern Slavery Statement
            </a>
          </li>
        </ul>
      </div>

      <div class="col-lg-2 col-md-3 col-6">
        <h6 class="footer-title">Quick links</h6>
        <ul class="footer-list">
          <li>
            <a class="footer-link" href="/" title="Book a Discovery Call">
              Book a Discovery Call
            </a>
          </li>
          <li>
            <a class="footer-link" href="/contact-us" title="Contact">
              Contact
            </a>
          </li>
          <li>
            <a class="footer-link" href="/sitemap">
              Sitemap
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider & Bottom Area -->
    <div class="footer-divider"></div>
    
    <div class="footer-bottom">
      <div class="footer-copyright">
        &copy; {new Date().getFullYear()} <a href="/">Digital Back Office</a>. All rights reserved.
      </div>
      <a href="#" class="back-to-top-link" aria-label="Back to top">
        <span>Back to top</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
      </a>
    </div>
  </div>
</footer>
