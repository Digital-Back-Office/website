---
import '../../styles/global.css'
const path = Astro.url.pathname;
import Button from "../ui/Button.astro";
---

<header
  id="navbar"
  class="staticnav nav navbar navbar-expand-lg"
  data-pagefind-ignore
>
  <div class="container">
    <a class="navbar-brand" href="/">
      <span class="text-primary flex-shrink-0 me-2">
        <img src="/assets/images/dbo_1.png" alt="DBO logo" class="brand-logo" />
      </span>
    </a>

    <button
      type="button"
      class="navbar-toggler"
      data-bs-toggle="collapse"
      data-bs-target="#navbarCollapse2"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <nav class="collapse navbar-collapse" id="navbarCollapse2">
      <ul class="navbar-nav">
        <li class={path.includes("/industry") ? "nav-item dropdown active" : "nav-item dropdown"}>
          <a
            href="javascript:void(0)"
            class={path.includes("/industry")?"nav-link nav-links active-link":"nav-link nav-links"}
            aria-expanded="false"
          >Industries</a>
          <ul class="dropdown-menu">
            <li>
              <a href="/industry/finance-and-insurance" title="Finance" class="dropdown-item nav-links">Finance</a>
            </li>
            <li>
              <a href="/industry/healthcare-life-sciences" title="Healthcare" class="dropdown-item nav-links">Healthcare</a>
            </li>
            <li>
              <a href="/industry/retail-and-e-commerce" title="Retail" class="dropdown-item nav-links">Retail</a>
            </li>
            <!--li>
              <a href="/industry/industrials-manufacturing-and-energy" title="Energy" class="dropdown-item nav-links">Energy</a>
            </li-->
            <li>
              <a href="/industry/technology-media-and-telecom" title="Media" class="dropdown-item nav-links">Media</a>
            </li>
             <li>
              <a href="/startups" title="For startups" class="dropdown-item nav-links">For startups</a>
            </li>
          </ul>
        </li>

        <li class="nav-item dropdown">
          <a
            class={path.includes("/services")?"nav-link  nav-links active-link":"nav-link nav-links"}
            data-bs-auto-close="outside"
            aria-expanded="false">Services</a
          >
          <ul class="dropdown-menu">
            <li>
              <a href="/services/ai-solutions" title="AI Transformation" class="dropdown-item nav-links">AI Transformation</a>
            </li>
            <li>
              <a href="/services/data-strategy-services" title="Data Strategy" class="dropdown-item nav-links">Data Strategy</a>
            </li>
            <li>
              <a href="/services/data-engineering-services" title="Data Engineering" class="dropdown-item nav-links">Data Engineering</a>
            </li>
            <li>
              <a href="/services/data-science" title="Data Science" class="dropdown-item nav-links">Data Science</a>
            </li>
          </ul>
        </li>

        <li class={path.includes("/about-us") ? "nav-item active" : "nav-item"}>
          <a href="/about-us" title="About Us" class="nav-link nav-links">About Us</a>
        </li>
        <li class={path.includes("/startups") ? "nav-item active" : "nav-item"}>
          <a href="/startups" title="For startups" class={path.includes("/startups") ? "nav-link nav-links active-link d-flex align-items-center" : "nav-link nav-links d-flex align-items-center"}>
            For startups <span class="startups-pulse-dot"></span>
          </a>
        </li>

<style>
  .startups-pulse-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: #52CEC7;
    border-radius: 50%;
    margin-left: 6px;
    vertical-align: middle;
    box-shadow: 0 0 0 0 rgba(82, 206, 199, 0.7);
    animation: pulse-dot 1.8s infinite cubic-bezier(0.66, 0, 0, 1);
  }

  @keyframes pulse-dot {
    to {
      box-shadow: 0 0 0 8px rgba(82, 206, 199, 0);
    }
  }
</style>
        <li class="nav-item dropdown">
          <a
            class={(path.includes("/blog") || path.includes("/events") || path.includes("/partners") || path.includes("/industry-insights"))?"nav-link  nav-links active-link":"nav-link nav-links"}
            data-bs-auto-close="outside"
            aria-expanded="false">Resources</a
          >
          <ul class="dropdown-menu">
            <li>
              <a href="/blog/1" title="Blogs" class="dropdown-item nav-links">Blogs</a>
            </li>
            <li>
              <a href="/industry-insights" title="Industry Insights" class="dropdown-item nav-links">Industry Insights</a>
            </li>
            <!-- <li>
              <a href="#" class="dropdown-item nav-links">Events</a>
            </li>
            <li>
              <a href="/partners" class="dropdown-item nav-links">Partners</a>
            </li> -->
          </ul>
        </li>
      </ul>

      <Button
        href="/contact-us"
        variant="primary"
        size="lg"
        class="d-lg-none"
      >
        Book a free consultation
      </Button>
    </nav>

    <Button
      href="/contact-us"
      variant="primary"
      size="md"
      class={path.includes("/contact-us")
        ? "book-button d-none"
        : "book-button d-lg-inline-flex"}
    >
      Book a free consultation
    </Button>
  </div>

  <div class="pop-up" id="pop-up" data-pagefind-ignore>
    <div class="pop-up-text">
        Form Submitted Successfully!!
    </div>
  </div>
</header>

<style is:global>
  /* Header Wrapper styling - Modern Opaque */
  #navbar {
      height: 80px;
      display: flex;
      align-items: center;
      transition: all var(--motion-base);
      border-bottom: 1px solid transparent;
      z-index: 100;
  }

  /* Scrolled State styling */
  #navbar.navbar-scrolled {
      background-color: #ffffff !important;
      border-bottom: 1px solid var(--border-subtle);
      box-shadow: 0 4px 20px rgba(15, 23, 42, 0.03);
      height: 70px; /* Subtle height transition on scroll */
  }

  /* Static State styling */
  #navbar.staticnav {
      background-color: #f7f9fc !important;
      border-bottom: 1px solid transparent;
  }

  /* Brand Logo */
  .brand-logo {
      height: 38px !important;
      width: auto;
      transition: transform var(--motion-base);
  }

  .navbar-brand:hover .brand-logo {
      /* Removed scale effect */
  }

  /* Sleek, premium nav links */
  .navbar-nav {
      align-items: center;
      gap: var(--space-2);
  }

  .navbar-nav .nav-link.nav-links {
      font-size: 0.925rem !important;
      font-weight: 600 !important;
      color: var(--text-secondary) !important;
      padding: 0.5rem 1rem !important;
      transition: all var(--motion-base) !important;
      border-radius: var(--radius-md);
  }

  .navbar-nav .nav-link.nav-links:hover {
      color: var(--brand-teal-deep) !important;
      background-color: rgba(48, 186, 186, 0.05);
  }

  /* Ensure dropdown toggle links are hoverable and show pointer cursors */
  .navbar-nav .dropdown > a {
      pointer-events: auto !important;
      cursor: pointer !important;
  }

  .navbar-nav .nav-link.nav-links.active-link {
      color: var(--brand-cyan) !important;
  }

  /* Dropdown Menu overrides - Glassmorphic look */
  .navbar-nav .dropdown-menu {
      background: var(--bg-surface) !important;
      border: 1px solid var(--border-subtle) !important;
      box-shadow: var(--shadow-lg) !important;
      border-radius: var(--radius-lg) !important;
      padding: 0.5rem !important;
      margin-top: 0.5rem !important;
      animation: navDropdownFade 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes navDropdownFade {
      from {
          opacity: 0;
          transform: translateY(6px);
      }
      to {
          opacity: 1;
          transform: translateY(0);
      }
  }

  .navbar-nav .dropdown-menu .dropdown-item {
      font-size: 0.875rem !important;
      font-weight: 500 !important;
      color: var(--text-secondary) !important;
      padding: 0.5rem 0.85rem !important;
      border-radius: var(--radius-md) !important;
      transition: all var(--motion-fast) !important;
  }

  .navbar-nav .dropdown-menu .dropdown-item:hover {
      background-color: rgba(48, 186, 186, 0.06) !important;
      color: var(--brand-teal-deep) !important;
  }

  /* Mobile menu button styling */
  .navbar-toggler {
      border: none !important;
      padding: 0.25rem !important;
  }

  .navbar-toggler:focus {
      box-shadow: none !important;
  }

  /* Mobile Collapse Styling */
  @media (max-width: 991.98px) {
      /* Hamburger takes over here and the collapsed menu carries its own
         CTA, so the header one would be a duplicate. */
      .book-button {
          display: none !important;
      }

      #navbar {
          height: auto;
          padding: 0.75rem 0;
      }

      .navbar-collapse {
          background-color: var(--bg-surface) !important;
          border: 1px solid var(--border-subtle);
          border-radius: var(--radius-xl);
          padding: 1.25rem !important;
          margin-top: 1rem !important;
          box-shadow: var(--shadow-lg) !important;
      }

      .navbar-nav {
          align-items: stretch;
          gap: 0;
      }

      .navbar-nav .nav-link.nav-links {
          font-size: 0.95rem !important;
          padding: 0.75rem 0.5rem !important;
          border-bottom: 1px solid var(--border-subtle);
          border-radius: 0;
      }

      .navbar-nav .nav-link.nav-links:hover {
          background-color: transparent;
          color: var(--brand-teal-deep) !important;
      }

      .navbar-nav .nav-item:last-child .nav-link {
          border-bottom: none;
      }

      .navbar-nav .dropdown-menu {
          box-shadow: none !important;
          border: none !important;
          padding-left: 1rem !important;
          background: transparent !important;
          margin-top: 0 !important;
      }
  }
</style>
