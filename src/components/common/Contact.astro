---
import "../../styles/contact.css";
---

<section class="contact-section d-flex align-items-center">
    <div class="container contact-inner py-5">
        <div class="row align-items-stretch g-5">
            <!-- Left Side: Header and Integrated Form -->
            <div class="col-lg-5">
                <div class="contact-form-wrapper">
                    <div class="contact-header-left">
                        <h2 class="contact-title">Let's Build with <span>AI</span></h2>
                        <p class="contact-desc">
From AI strategy and automation to custom machine learning applications, we create solutions that help organizations innovate faster, operate smarter, and scale with confidence.                        </p>
                    </div>
                    
                    <p class="contact-form-subtitle">Complete the form below, and we'll respond within 24 hours.</p>
                    
                    <form
                        class="needs-validation contact-form row g-3"
                        action="https://formsubmit.co/contact@digitalbackoffice.co.uk"
                        method="POST"
                        novalidate
                    >
                        <div class="col-12 form-group">
                            <label class="form-label" for="name">Name</label>
                            <input
                                class="form-control"
                                type="text"
                                placeholder="Your name"
                                required
                                name="name"
                                id="name"
                            />
                            <div class="invalid-feedback">
                                Please enter your name!
                            </div>
                        </div>
                        <div class="col-12 form-group">
                            <label class="form-label" for="email">Email</label>
                            <input
                                class="form-control"
                                type="email"
                                placeholder="Email address"
                                required
                                name="email"
                                id="email"
                            />
                            <div class="invalid-feedback">
                                Please provide a valid email address!
                            </div>
                        </div>
                        <div class="col-12 form-group">
                            <label class="form-label" for="message">Message</label>
                            <textarea
                                class="form-control"
                                placeholder="Your message"
                                rows="3"
                                required
                                name="message"
                                id="message"></textarea>
                            <div class="invalid-feedback">
                                Please write your message!
                            </div>
                        </div>
                        <div class="col-12 pt-2">
                            <button
                                class="contact-submit-btn"
                                type="submit">Send Now</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Right Side: Pipeline Flow Diagram Box -->
            <div class="col-lg-7 d-flex align-items-center">
                <div class="pipeline-graphic-box">
                    <!-- Flow Connections -->
                    <svg class="pipeline-svg" width="100%" height="100%" viewBox="0 0 500 400" preserveAspectRatio="none">
                        <!-- Dotted paths -->
                        <path d="M135,140 Q207,140 207,200" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="4 4" fill="none" />
                        <path d="M135,200 L207,200" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="4 4" fill="none" />
                        <path d="M135,260 Q207,260 207,200" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="4 4" fill="none" />
                        
                        <path d="M293,200 L336,200" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="4 4" fill="none" />
                        
                        <!-- Flow pipeline animations -->
                        <path class="pipeline-flow-1" d="M135,140 Q207,140 207,200" stroke="var(--brand-cyan)" stroke-width="2" stroke-linecap="round" fill="none" />
                        <path class="pipeline-flow-2" d="M135,200 L207,200" stroke="var(--brand-cyan)" stroke-width="2" stroke-linecap="round" fill="none" />
                        <path class="pipeline-flow-3" d="M135,260 Q207,260 207,200" stroke="var(--brand-cyan)" stroke-width="2" stroke-linecap="round" fill="none" />
                        <path class="pipeline-flow-4" d="M293,200 L336,200" stroke="var(--brand-cyan)" stroke-width="2" stroke-linecap="round" fill="none" />
                    </svg>

                    <!-- Source Nodes (Left Column) -->
                    <div class="pipeline-column">
                        <div class="pipeline-node">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                            <span>24/7 Support</span>
                        </div>
                        <div class="pipeline-node">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5"></polygon>
                                <line x1="12" y1="22" x2="12" y2="15.5"></line>
                                <polyline points="22 8.5 12 15.5 2 8.5"></polyline>
                            </svg>
                            <span>Impossible? On it</span>
                        </div>
                        <div class="pipeline-node">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                <polyline points="14 2 14 8 20 8"></polyline>
                            </svg>
                            <span>Flexible Terms</span>
                        </div>
                    </div>

                    <!-- Processing Engine Core (Center) -->
                    <div class="pipeline-core-wrapper">
                        <div class="pipeline-core">
                            <div class="core-pulse-1"></div>
                            <div class="core-pulse-2"></div>
                            <div class="core-inner-icon">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                                    <polyline points="2 17 12 22 22 17"></polyline>
                                    <polyline points="2 12 12 17 22 12"></polyline>
                                </svg>
                            </div>
                        </div>
                        <span class="core-label">DBO AI Engine</span>
                    </div>

                    <!-- Insights Display Widget (Right) -->
                    <div class="pipeline-insights-card">
                        <div class="insights-header">
                            <span class="insights-badge">Full Spectrum</span>
                            <span class="insights-value">Active</span>
                        </div>
                        <div class="insights-chart">
                            <div class="chart-bar" style="height: 40%;"></div>
                            <div class="chart-bar active" style="height: 75%;"></div>
                            <div class="chart-bar" style="height: 50%;"></div>
                            <div class="chart-bar active" style="height: 90%;"></div>
                            <div class="chart-bar" style="height: 60%;"></div>
                        </div>
                        <div class="insights-footer">
                            <span class="insights-metric">Growth Analytics</span>
                            <span class="insights-trend">+24% Efficiency</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
