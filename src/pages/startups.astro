---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/startups/Hero.astro";
import Dilemma from "../components/startups/Dilemma.astro";
import Capabilities from "../components/startups/Capabilities.astro";
import IndustryVerticals from "../components/startups/IndustryVerticals.astro";
import HowItWorks from "../components/startups/HowItWorks.astro";
import Pricing from "../components/startups/Pricing.astro";
import FAQ from "../components/startups/FAQ.astro";
import ApplyForm from "../components/startups/ApplyForm.astro";
import "../styles/startups.css";

const seoTitle = "Elite Engineering Team for Startups - Digital Back Office";
const seoDescription =
  "Turn your startup idea into a scalable product with our elite engineering team on a pre-seed budget. Complete DevOps, backend, UI, and AI development starting from £2,500/mo.";
const seoKeywords =
  "startup engineering, pre-seed tech team, outsourced CTO, MVP development, startup developer team, fractional engineering team, startups DevOps, startups AI integration";
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  canonical="/startups"
  preview_image="/startup_preview.png"
>
  <script type="application/ld+json" slot="head" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is an engineering Team?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "An engineering Team is a fixed-cost, fully-managed software team, typically a designer, developers, and a DevOps engineer working under one Tech Lead, that builds your product as a single unit, instead of you hiring and managing each specialist separately."
          }
        },
        {
          "@type": "Question",
          "name": "How much does a startup engineering team cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Plans start at £2,500/month on a flat-rate, all-inclusive basis, covering design, development, DevOps, and AI integration in one invoice."
          }
        },
        {
          "@type": "Question",
          "name": "How quickly can we start?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most pods are onboarded and writing code within 48 hours of your application being approved."
          }
        }
      ]
    }
  </script>
  <script type="application/ld+json" slot="head" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Dedicated Engineering Team for Startups",
      "provider": {
        "@type": "Organization",
        "name": "Digital Back Office",
        "url": "https://digitalbackoffice.co.uk"
      },
      "areaServed": "GB",
      "offers": {
        "@type": "Offer",
        "price": "2500",
        "priceCurrency": "GBP",
        "priceSpecification": {
          "@type": "UnitPriceSpecification",
          "price": "2500",
          "priceCurrency": "GBP",
          "billingDuration": "P1M"
        }
      }
    }
  </script>

  <main class="page-wrapper" data-pagefind-ignore>
    <Hero />
    <Dilemma />
    <Capabilities />
    <IndustryVerticals />
    <HowItWorks />
    <Pricing />
    <FAQ />
    <ApplyForm />
  </main>
</Layout>
