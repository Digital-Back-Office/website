---

export interface Props {
  src: string;
}

const { src } = Astro.props;
import '../styles/container.css'
---

<style>
  .top-sec {
    position: relative;
    z-index: 2;
    /* height: 64rem; */
    width: 100%;
  }

  .top-sec::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.65) 0%,
      rgba(18, 21, 25, 0.85) 100%
    );
    background-repeat: repeat;
    z-index: 2;
  }

  .hero-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }
</style>

<main>
  <Navbar />
  <div class="top-sec">
    <video class="hero-video" src={src} preload="auto" muted autoplay loop>
    </video>
    
    <slot />
  </div>
</main>
