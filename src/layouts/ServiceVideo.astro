---
import Navbar from "../components/common/Navbar.astro";

export interface Props {
  src: string;
}

const { src } = Astro.props;
import '../styles/container.css'
---

<style>
  .hero-section {
    width: 100%;
    height: 100vh;
    max-height: 110vh;
    position: relative;
    overflow: hidden;
    background-color: var(--bg-base);
  }

  .hero-section::before {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .hero-section * {
    z-index: 3;
  }
  
  .hero-text {
    position: absolute;
    top: 70vh;
    left: 0;
    right: 0;
    z-index: 10;

  }

    @media screen and (max-width: 1024px) {
      .hero-section {
        height: 1000px;
        overflow: hidden;
      }

      .hero-video {
        height: 1000px;
      }
    }
</style>

<section class="hero-section">

  <slot />
</section>
