---
export interface Props {
  videoSrc?: string;
}

const { videoSrc } = Astro.props;
import Navbar from "../components/common/Navbar.astro";
import '../styles/container.css'
---

<style>
  .hero-section {
    width: 100%;
    padding: 160px 0 80px 0;
    position: relative;
    overflow: hidden;
    background-color: transparent;
    display: flex;
    align-items: center;
  }

  .hero-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      rgba(247, 249, 252, 0.95) 0%,
      rgba(247, 249, 252, 0.75) 45%,
      rgba(247, 249, 252, 0.05) 100%
    ),
    linear-gradient(
      180deg,
      rgba(247, 249, 252, 0.1) 0%,
      rgba(247, 249, 252, 0.5) 75%,
      var(--bg-base) 100%
    );
    z-index: 2;
  }

  .hero-content-container {
    position: relative;
    z-index: 3;
    width: 100%;
  }
</style>

<Navbar />
<section class="hero-section">
  {videoSrc && (
    <video class="hero-video" src={videoSrc} preload="auto" muted autoplay loop playsinline></video>
  )}
  {videoSrc && <div class="hero-overlay"></div>}
  <div class="hero-content-container">
    <slot />
  </div>
</section>
